		<Item id ="1107" name="Lg"           symbol="log10("	expression="Execute.Lg("   image="Log10"   info="y = log10(x)：对序列 x 中每个元素的求以 10 为底的对数\n   x：输入序列或数值, 满足 x &gt; 0;\n   y：返回以 10 为底的对数序列" />
		<Item id ="1108" name="平方"         symbol="square("	expression="Execute.Square("   image="Square"   info="y = square(x)：对序列 x 中每个元素的求平方\n   x：输入序列或数值;\n   y：返回平方序列, 满足 y ≥ 0" />
		<Item id ="1109" name="平方根"       symbol="sqrt("		expression="Execute.Sqrt("   image="Sqrt"   info="y = sqrt(x)：对序列 x 中每个元素的求平方根\n   x：输入序列或数值, 满足 x ≥ 0;\n   y：返回平方根序列, 满足 y ≥ 0" />
		<Item id ="1110" name="共模"         symbol="comm("		expression="Execute.Comm("   image="ComMode"   info="z = comm(x, y)：求序列 x 和 y 中对应元素的共模\n   x 和 y：输入序列或数值;\n   z：返回共模序列或数" />
