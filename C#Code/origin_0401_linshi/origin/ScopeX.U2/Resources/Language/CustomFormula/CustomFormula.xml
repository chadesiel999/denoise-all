		<Item id ="1116" name="扩展"         symbol="zoom("  expression="Execute.Zoom("  image="Zoom"     info="y = zoom(x, s, d)：扩展显示 x 序列中的一部分\n   x：输入序列;\n   s：扩展范围起始时间, 以秒为单位;\n   d：扩展范围大小，以秒为单位;\n   y：返回扩展序列" />       
