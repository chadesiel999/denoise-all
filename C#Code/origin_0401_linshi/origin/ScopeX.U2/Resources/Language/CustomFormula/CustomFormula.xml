		<Item id ="1119" name="最大值"       symbol="max("  expression="Execute.MaxSubVector("   image="Max"   info=" y = max(x, g)：求序列 x 每个水平区间上的垂直最大值\n   x：输入序列;\n   g：水平区间大小, 以秒为单位, 满足 g &gt; 0;\n   y：返回最大值序列" />  
