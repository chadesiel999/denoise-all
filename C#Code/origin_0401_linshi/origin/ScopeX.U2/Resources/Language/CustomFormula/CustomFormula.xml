		<Item id ="1104" name="微分"         symbol="diff("		expression="Execute.Der("   image="Der"     info="y = diff(x)：求序列 x 的向后微分\n   x：输入序列或数值;\n   y：返回微分序列" />
		<Item id ="1105" name="积分"         symbol="int("		expression="Execute.Int("   image="Int"     info="y = int(x)：求序列 x 的积分\n   x：输入序列或数值;\n   y：返回积分序列" />
