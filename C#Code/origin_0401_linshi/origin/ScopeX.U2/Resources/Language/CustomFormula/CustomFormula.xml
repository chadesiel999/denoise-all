		<Item id ="1112" name="余弦"         symbol="cos("		expression="Execute.Cos("   image="Cos"   info="y = cos(θ)：对序列 θ 中每个元素的求余弦\n   θ：输入序列或数值，以弧度为单位;\n   y：返回余弦序列或数, 满足 -1 ≤ y ≤ +1" />
		<Item id ="1113" name="正切"         symbol="tan("		expression="Execute.Tan("   image="Tan"   info="y = tan(θ)：对序列 θ 中每个元素的求正切\n   θ：输入序列或数值，以弧度为单位;\n   y：返回正切序列或数" />
