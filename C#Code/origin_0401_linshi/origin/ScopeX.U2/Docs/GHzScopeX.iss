<event('DeinitializeSetup')>
procedure DeinitializeSetupSysTime;
var 
  StartTime, ResultTime, Currenttime: SYSTEMTIME;
  TimeDifference: Integer;
begin
  StartTime.wYear := 2024;
  StartTime.wMonth := 3;
  StartTime.wDay := 1;
  StartTime.wHour := 12;
  StartTime.wMinute := 0;
  StartTime.wSecond := 0;
  StartTime.wMilliseconds := 0;
  // 获取当前时间
  GetLocalTime(Currenttime);
  // 计算时间差值，秒数
  TimeDifference := SystemTimeToMilliseconds(Currenttime) - SystemTimeToMilliseconds(StartTime);
  // 将时间差加到原始记录时间中去
  AddMillisecondsToSystemTime(SystemTimeRecord, TimeDifference);
  // 恢复原始系统时间
  SetLocalTime(SystemTimeRecord);
end;

{运行Dos命令}
function RunDosCommand(const Cmd: String): Boolean;
var
  ResultCode: Integer;
begin
  Result := Exec('cmd.exe', '/C ' + Cmd, '', SW_HIDE, ewWaitUntilTerminated, ResultCode);
end;

{ 查找指定路径下的指定后缀的所有文件路径，并返回 }
function FindFilesInFolder(const AFolder: String; const AExtension: String): TStringList;
var
  FindRec: TFindRec;
  FilePath: String;
begin
  Result := TStringList.Create;
  if FindFirst(AFolder + '\*' + AExtension, FindRec) then
  begin
    try
      repeat
        if FindRec.Attributes and FILE_ATTRIBUTE_DIRECTORY = 0 then
        begin
          FilePath := AFolder + '\' + FindRec.Name;
          Result.Add(FilePath);
        end;
      until not FindNext(FindRec);
    finally
      FindClose(FindRec);
    end;
  end;
end;

{ 从路径中获取文件名称 }
function ExtractFileName(Path: String): String;
var
  FileName: String;
begin
  FileName := Path;
  while Pos('\', FileName) > 0 do
    FileName := Copy(FileName, Pos('\', FileName) + 1, Length(FileName));
  Result := FileName;
end;

function MultiByteToWideChar(
  CodePage: UINT; dwFlags: DWORD; const lpMultiByteStr: AnsiString;
    cchMultiByte: Integer; lpWideCharStr: string; cchWideChar: Integer): Integer;
  external 'MultiByteToWideChar@kernel32.dll stdcall';  

{ 读取文件文本内容，并将其转为UTF-8字符 }
function LoadStringFromFileInCP(
  FileName: string; var S: string; CP: Integer): Boolean;
var
  Ansi: AnsiString;
  Len: Integer;
begin
  Result := LoadStringFromFile(FileName, Ansi);
  if Result then
  begin
    Len := MultiByteToWideChar(CP, 0, Ansi, Length(Ansi), S, 0);
    SetLength(S, Len);
    MultiByteToWideChar(CP, 0, Ansi, Length(Ansi), S, Len);
  end;
end;

function LoadStringsFromFileInCP(
  FileName: string; Strings: TStrings; CP: Integer): Boolean;
var
  S: string;
begin
  Result := LoadStringFromFileInCP(FileName, S, CP);
  if Result then Strings.Text := S;
end;

{ 使用UTF-8-8读取文件内容 }
function LoadUTF8FileToString(FileName: String): String;
var
  Strings: TStrings;
begin
  Result := '';
  Strings := TStringList.Create;
  // 打开文件并读取内容
  if LoadStringsFromFileInCP(FileName, Strings, CP_UTF8) then
  begin
    Result := Strings.Text;
  end;
  Strings.Free;
end;


{ 固件升级 }
procedure FirmwareUpdate;
var
  UpdateExeFolder: String;
  UpdateExeFullPath: String;
  UPdateMsgFileFullPath: String;
  FilesList: TStringList;
  FilePath: String;
  I: Integer;
  ResultCode: Integer;
  Updatingmsg: String;
  Updatingmsgtmp: String;
  ExtractFileNameStr: String;
  RestartMsg: String;
  LanguageName: String;
  LangStr: String;
begin
  // 是否选中了固件升级项
  if IsTaskSelected('firmwareUpdate') then
  begin
    
    LanguageName := ActiveLanguage;
    case LanguageName of
      'english': LangStr := 'en';
      'chinesesimplified': LangStr := 'zh_cn';
      else
      LangStr := 'zh_cn';
    end;

    // 判断升级程序的目录是否存在，如果目录都不存在，则不予执行
    UpdateExeFullPath := ExpandConstant('{tmp}\Update\ScopeX.Updater.exe');
    UPdateMsgFileFullPath := ExpandConstant('{tmp}\Update\innosetupmsg.txt');
    if FileExists(UpdateExeFullPath) then
    begin
      if FileExists(UPdateMsgFileFullPath) then
      begin
        DeleteFile(UPdateMsgFileFullPath)
      end;

      RestartMsg := ExpandConstant('{cm:CodeFirmwareUpdateSuccessRestart}');
      Updatingmsg := ExpandConstant('{cm:CodeFirmwareUpdateUp}');
      UpdateExeFolder := ExpandConstant('{tmp}\Update');
      // 查找所有的*.upd文件
      FilesList := FindFilesInFolder(UpdateExeFolder, '.upd');
      for I := 0 to FilesList.Count - 1 do
      begin
        FilePath := FilesList[I];
        ExtractFileNameStr := ExtractFileName(FilePath);
        Updatingmsgtmp := Format(Updatingmsg, [ExtractFileNameStr]);    
        // 执行升级安装，目前由于安装程序只能支持一个upd中升级一个固件，还不支持一个upd文件中同时升级多个固件，所以要找到所有的upd文件，一个一个安装。
        //WizardForm.StatusLabel.Caption := '正在升级固件：' + ExtractFileName(FilePath) + '，请稍后……';
        WizardForm.StatusLabel.Caption := Updatingmsgtmp;
        Exec(UpdateExeFullPath, '/lang=' + LangStr + ' /q "' + FilePath + '"', '', SW_HIDE, ewWaitUntilTerminated, ResultCode);
        // MsgBox('Found file: ' + FilePath, mbInformation, MB_OK);
      end;
      FilesList.Free;

      if FileExists(UPdateMsgFileFullPath) then
      begin
        // 读取升级程序产生的消息文件内容，并将内容使用消息框显示出来
        MsgBox(LoadUTF8FileToString(UPdateMsgFileFullPath) + #13#10 + RestartMsg, mbInformation, MB_OK);
        DeleteFile(UPdateMsgFileFullPath)
      end
      else
      begin
        MsgBox(RestartMsg, mbInformation, MB_OK);
      end;
    end;
  end;
end;

procedure CurStepChanged(CurStep: TSetupStep);
var 
  DosSuccess: boolean;
  LangTipXml: String;
  CannotDeleteFileMsg: String;
begin
  if CurStep = ssPostInstall then
  begin

    // 删掉以前项目生成时，自动拷贝的多语言资源文件，会导致优先以Resources文件夹下的多语言资源为准去了
    LangTipXml := ExpandConstant('{app}\Resources\Tip.xml');
    // 检查文件是否存在
    if FileExists(LangTipXml) then
    begin
      // 删除文件
      CannotDeleteFileMsg := Format(ExpandConstant('{cm:CodeCanNotDeleteFile}'), [LangTipXml]);
      if not DeleteFile(LangTipXml) then
        MsgBox(CannotDeleteFileMsg, mbError, MB_OK);
    end;


    // 固件升级
    FirmwareUpdate();

    { 
      执行Dos命令设置系统睡眠方案为：永不睡眠
      微软官方地址：https://learn.microsoft.com/zh-cn/windows-hardware/design/device-experiences/powercfg-command-line-options 

      修改当前电源方案中的设置值：直流和交流方案都不进入睡眠
      powercfg /change /standby-timeout-ac 0
      powercfg /change /standby-timeout-dc 0

      禁用休眠功能
      powercfg /hibernate off
    }
    // disabledsleep
    if IsTaskSelected('disabledsleep') then
    begin
      DosSuccess := RunDosCommand('powercfg /change /standby-timeout-ac 0 & powercfg /change /standby-timeout-dc 0 & powercfg /hibernate off');
    end;
    // 在安装完成后调用 RefreshDesktop 函数刷新桌面
    RefreshDesktop;
    // MsgBox('安装已完成，禁用睡眠在系统重启后生效！', mbInformation, MB_OK);
  end;
end;

function IsRegistryKeyExists(const RegKey: string): Boolean;
begin
  Result := RegKeyExists(HKLM, RegKey) or RegKeyExists(HKCU, RegKey);
end;

function ShouldInstallDotNet6: Boolean;
var
  InstallerPath: string;
begin
  Result := True;
  // 检测是否有安装.NET 6，用以判断是否释放和执行.Net6安装包 
  if IsRegistryKeyExists('SOFTWARE\WOW6432Node\dotnet\Setup\InstalledVersions') then
  begin
    Result := False;
  end;
end;

type FileVersionInfo = record
      Major: Cardinal;
      Minor: Cardinal;
      Rev: Cardinal;
      Build: Cardinal;
    end;

(* 获取文件版本号，并返回四位的版本号字符串 *)
function MyGetVersionNumbersString(
  const Filename: String; var Version: String): Boolean;
var
  MS, LS: Cardinal;
  Major, Minor, Rev, Build: Cardinal;
begin
  Result := GetVersionNumbers(Filename, MS, LS);
  if Result then
  begin
    Major := MS shr 16;
    Minor := MS and $FFFF;
    Rev := LS shr 16;
    Build := LS and $FFFF;
    Version := Format('%d.%d.%d.%d', [Major, Minor, Rev, Build]);
  end
end;

(* 获取文件版本号，并返回四位的版本号数字 *)
function SXGetFileVersion(
  const Filename: String; var Version: FileVersionInfo): Boolean;
var
  MS, LS: Cardinal;
  Major, Minor, Rev, Build: Cardinal;
begin
  Result := GetVersionNumbers(Filename, MS, LS);
  if Result then
  begin
    Major := MS shr 16;
    Minor := MS and $FFFF;
    Rev := LS shr 16;
    Build := LS and $FFFF;
    // Version := Format('%d.%d.%d', [Major, Minor, Rev]);
    Version.Major := Major;
    Version.Minor := Minor;
    Version.Rev := Rev;
    Version.Build := Build;    
    {*with Version do
    begin
      Major := Major;
      Minor := Minor;
      Rev := Rev;
      Build := Build;
    end;*}
  end
end;

function ShouldInstallEdge(): Boolean;
var
  MsedgePath: string;
  MsedgeExist: boolean;
  CurrentEdgeVersion: FileVersionInfo; (* Declare CurrentEdgeVersion of type FileVersionInfo *)
begin
  // 判断是否需要安装Edge
  Result := False;
  MsedgePath := 'C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe';
  if FileExists(MsedgePath) then
  begin
    MsedgeExist := SXGetFileVersion(MsedgePath,CurrentEdgeVersion);
    // CurrentEdgeVersion 和 117.0.2045.43 比较，决定是否需要安装EDGE
    if MsedgeExist then
     begin
      if CurrentEdgeVersion.Major < 117 then  (* 目前只比较主版本号就行了 *)
        Result := True;
     end;
  end 
  else
  begin
    Result := True;
  end;
end;


{ 用于判断是否使用旧版安装程序安装了U2,如果安装了，则先卸载掉 }
function IsProgramInstalled(const OldAppID: string): Boolean;
var
  ProductID: string;
  UninstallKey: string;
begin
  // 获取产品 ID
  // ProductID := ExpandConstant('{#OldAppID}');

  // 计算机\HKEY_LOCAL_MACHINE\SOFTWARE\WOW6432Node\Caphyon\Advanced Installer\LZMA\{6BACBB06-C81F-414B-B567-6C29BC569865}

  // 构建卸载键路径
  UninstallKey := 'SOFTWARE\WOW6432Node\Caphyon\Advanced Installer\LZMA\' + OldAppID;   

  // 检查注册表中是否存在卸载键
  if RegKeyExists(HKEY_LOCAL_MACHINE, UninstallKey) then
  begin
    // 存在指定产品 ID 的程序
    Result := True;
  end
  else
  begin
    // 不存在指定产品 ID 的程序
    Result := False;
  end;
end;

{ 安装程序初始化 }
function InitializeSetup(): Boolean;
var 
  IsInstalledOldApp: Boolean;
  ResultCode: Integer;
begin
  IsInstalledOldApp := IsProgramInstalled('{161E294F-AE02-46BB-A40A-C06C419F1814}') or IsProgramInstalled('{6BACBB06-C81F-414B-B567-6C29BC569865}');
  if IsInstalledOldApp then
  begin
    ResultCode := MsgBox(ExpandConstant('{cm:CodeOldVersionCheckMsg}'), mbInformation, MB_OK);
    Result := False;
  end
  else
  begin
    Result := True;
  end;
end;