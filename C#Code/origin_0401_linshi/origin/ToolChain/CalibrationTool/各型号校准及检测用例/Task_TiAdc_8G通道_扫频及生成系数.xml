<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(OurDso), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="OurDso程控校准方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->

		<Instrumentation 
			Name="RS"
			Description="RS射频源"
			DriverType="VISA"
			Address="USB0::0x0AAD::0x0054::181630::INSTR"			
			IsOurTargetDso="false"
			Timeout="0"
			></Instrumentation>		

		<Instrumentation 
			Name="OurDso"
			Description="10G示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>

		<Task Description="8G-TIADC校准" ImportanceTipMessage="该任务是通过程控来校准示波器的TIADC误差。">
			<Command Description="删除保存目录下全部旧的文件" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=""
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_SystemCommand del @ToolRootPath@.\ScanFrequencyResultData\*.* /Q;"
			></Command>		
			<ForeachLoop StartIndex="0" Count="4" Description="指定通道">			
				<VarintDefine name="ChannelID" valuelist="1,2,3,4"></VarintDefine>	
				<Command Description="请将信号源输出接入到通道@ChannelID@上，并确保时基档与幅度档正确，处于Debug子带模式，关闭相关的数字处理" 
					InstrumentationName="OurDso"
					CommandType="check"
					SCPICmd=""
				></Command>	
				<ForeachByFileLine Description="扫频，并保存相关频点的采样原始数据" FileID="扫频频点表" FileName=".\各型号校准及检测用例\FreqTable_TiAdc_8G通道_扫频规划.txt">
					<Command Description="信号源输出@FID扫频频点表:Column1@" 
							InstrumentationName="RS"
							CommandType="scpi"
							SCPICmd=":FREQ @FID扫频频点表:Column1@"
							AfterWaitSec="0.5"								
					></Command>						
	
					<Command Description="保存频点@FID扫频频点表:Column1@的采集文件" 
							InstrumentationName="OurDso"
							CommandType="scpi"
							SCPICmd=""
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_SaveWaveData DataLength=10000,ChannelList=C@ChannelID@,SaveFileName=.\ScanFrequencyResultData\WaveData_C@ChannelID@_@FID扫频频点表:Column1@.txt"
					></Command>						
						
				</ForeachByFileLine>

				<Command Description="生成 通道@ChannelID@的TiAdc系数" 
						InstrumentationName="OurDso"
						CommandType="scpi"
						SCPICmd=""
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\MatlabDLL\MatlabGenerateCoefficientsTable_TiAdc.dll,CoefficientType=Coefficients2,Channel=CH@ChannelID@,SaveCoefficientFileName=.\TiAdcFiles\TiAdc_C@ChannelID@.txt,SourceFiles_Path=.\ScanFrequencyResultData,SourceFilesFilterPrefixName=WaveData_C@ChannelID@_,DebugSaveFilePath=.\TiAdcDebug,DebugSaveFilePrefixName=C@ChannelID@_,OtherParameter=2 20"
				></Command>						
				
			</ForeachLoop>					
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>