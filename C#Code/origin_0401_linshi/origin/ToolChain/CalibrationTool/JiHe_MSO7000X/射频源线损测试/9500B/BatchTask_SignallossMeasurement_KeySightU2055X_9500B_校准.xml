<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="信号源线损测试">
	<Instrumentations>
		<Instrumentation 
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB1::19::INSTR"
			Timeout="0"
		></Instrumentation>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="KeySight Power Meter U2055X"
			Description="KeySight功率计"
			DriverType="VISA"
			Address="USB0::0x2A8D::0x4B01::MY60000126::INSTR"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="对射频源及线损进行计算。" ImportanceTipMessage="该任务是通过程控来对9500B信号源的线损进行计算。">
			<Command Description="现在即将对信号源进行扫频，请确保将信号源的输出接入到相应的功率计！" 
				InstrumentationName="信号源复位"
				CommandType="check"
				SCPICmd=""
			></Command>
			<Command Description="信号源复位" 
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="*RST"
			></Command>
			<Command Description="设置通道1输出波形" 
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="ROUTe:SIGNal CH2"
			></Command>
			<Command Description="输出波形选择正弦波" 
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="SCOpe SIN"
			></Command>
			<Command Description="设置信号源输出频率为100MHz" 
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="FREQuency 1E8"
			></Command>
			<Command Description="信号源:高阻" 
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="ROUT:SIGN:IMP HIGH"
			></Command>
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="IMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<!--=======参数0dbm,低阻:0.2236 Vrms 高阻:0.775 Vrms=====-->
				<VarintDefine name="level"  valuelist="0.2236,0.775"></VarintDefine>		
				<Command Description="信号源:频率1MHz" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="FREQuency 1000000"
					AfterWaitSec="1"
				></Command>
				<!--<Command Description="设置信号源输出幅度0dBm" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SOURce:VOLTage:LEVel @level@ V"
				></Command>
				<Command Description="设置信号源输出幅度0dBm" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SOURce:VOLTage:UNIT VRMS"
				></Command>-->
				<Command Description="信号源:输出电平(@SourceAmpVoltByV@V) " 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="VOLTage @level@"
					AfterWaitSec="1"
				></Command>	
				<Command Description="信号源:阻抗(@SourceIMPedanceSetting@)Ω " 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUT:SIGN:IMP @SourceIMPedanceSetting@"
				></Command>
				<Command Description="打开信号源输出" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="OUTPut ON"
				></Command>
				<!--=======参数 1.是否更新dsp设计曲线 2.是否归一化 3.更新dsp设计曲线文件名前缀 4.报存线损的文件路径 5.保存的线损文件名 6.扫频的频点 7.信号源VISA地址 8.测量仪器VISA地址=====-->
				<Command Description="采集线损数据"
					InstrumentationName="GHz_MSO7000X"
					IsProgramFunc="true"
					ProgramFuncName="BatchTask_SignallossMeasurement false,true,@IMPedanceSetting@,PowerMeter,@IMPedanceSetting@_CaliPowerMeter.txt,扫频频率点表\@IMPedanceSetting@_CaliSignalLoss.txt,GPIB1::19::INSTR,USB0::0x2A8D::0x4B01::MY60000126::INSTR"
				></Command>
				<!--=======参数 1.是否更新dsp设计曲线 2.是否归一化 3.更新dsp设计曲线文件名前缀 4.报存线损的文件路径 5.保存的线损文件名=====-->
				<Command Description="生成dsp设计曲线"
					InstrumentationName="GHz_MSO7000X"
					IsProgramFunc="true"
					ProgramFuncName="BatchTask_SignallossMeasurement true,true,@IMPedanceSetting@,PowerMeter,@IMPedanceSetting@_CaliPowerMeter.txt"
				></Command>
				<Command Description="关闭信号源输出" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="OUTPut OFF"
				></Command>
			</ForeachLoop>
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>