<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="Afc扫频方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB0::19::INSTR"
			Timeout="0"
		></Instrumentation>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="对各个通道，阻抗，垂直档位，进行Afc扫频。" ImportanceTipMessage="该任务是通过程控来对各个通道，阻抗，垂直档位，进行Afc扫频。">
			<Group Description="信号源及示波器控制">
				<Command Description="检查信号源与示波器的连接情况" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="信号源复位" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="*RST"
				></Command>
				<Command Description="设置通道1输出波形" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUTe:SIGNal CH1"
				></Command>
				<Command Description="输出波形选择正弦波" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SCOpe SIN"
				></Command>
				<Command Description="设置信号源输出频率为100MHz" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="FREQuency 1E8"
				></Command>
				<Command Description="信号源:高阻" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUT:SIGN:IMP HIGH"
					></Command>
				<Command Description="设置时基到实时档（1us/div）"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 5E-7"
				></Command>
				<Command Description="打开正常采集模式" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe NORMal"
				></Command>
			</Group>	
			<Command Description="目标示波器状态准备：系统配置:关闭数字触发、关闭DSP"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:false,bEnable_Dsp:false"
			></Command>
			<ForeachLoop StartIndex="2" Count="1">
				<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
				<Command Description="现在即将对 “通道 (@OpenChannel@) ” 进行扫频，请确保将信号源的输出接入到相应的通道！" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<VarintDefine name="InterleaveName"  	valuelist="C1_10G,C2_10G,C3_10G,C4_10G"></VarintDefine>
				<VarintDefine name="OpenChannels"  	valuelist="C1,C2,C3,C4"></VarintDefine>
				<VarintDefine name="InterleaveNameBySamplingRate"  	valuelist="10G,10G,10G,10G"></VarintDefine>
				<VarintDefine name="BWLChannelStart"  	valuelist="0,0,0,0"></VarintDefine>
				<VarintDefine name="BWLChannelCount"  	valuelist="2,2,2,2"></VarintDefine>
				<!--==阻抗循环==-->							
				<ForeachLoop StartIndex="1" Count="1">	
					<VarintDefine name="SourceIMPedanceName"  valuelist="50欧姆,高阻"></VarintDefine>
			        <VarintDefine name="ScanFrePointTables"  valuelist="10G_LOW,10G_HIGH"></VarintDefine>
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>	
					<VarintDefine name="YScaleCount"  valuelist="3,3"></VarintDefine>
					<VarintDefine name="BWLStart"  valuelist="@BWLChannelStart@,0"></VarintDefine>
					<VarintDefine name="BWLCount"  valuelist="@BWLChannelCount@,1"></VarintDefine>
					<!--==带宽限制循环==-->
					<ForeachLoop StartIndex="@BWLStart@" Count="@BWLCount@">
						<VarintDefine name="Bandwidth"  valuelist="FULL,1GHz"></VarintDefine>
						<Group Description="常量设置">
							<ConstVariantDefine name="ScanFrequenciesFilePath" value="扫频频率点表\@InterleaveName@_@BatchTaskIMPedanceSetting@_@Bandwidth@.txt"></ConstVariantDefine>
							<ConstVariantDefine name="ScanFrequencyResultDataDir" value="ScanFrequencyResultData\@BatchTaskIMPedanceSetting@_@Bandwidth@"></ConstVariantDefine>
							<ConstVariantDefine name="ScanFrequencyResultFixDataDir" value="ScanFrequencyResultData\Data"></ConstVariantDefine>
						</Group>
						<Command Description="信号源:频率100MHz" 
								InstrumentationName="信号源9500B"
								CommandType="scpi"
								SCPICmd="FREQuency 100000000"
								AfterWaitSec="1"
								></Command>
						<Command Description="信号源:阻抗(@SourceIMPedanceName@) " 
							InstrumentationName="信号源9500B"
							CommandType="scpi"
							SCPICmd="ROUT:SIGN:IMP @SourceIMPedanceSetting@"
						></Command>
						<!--==挡位循环循环==-->	
					    <ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
							<VarintDefine name="SourceAmpVoltByMv" valuelist="0.10,0.5,3,0.20,2.0,3,10"></VarintDefine>
							<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,50,500,1000,10000"></VarintDefine>
							<Group Description="设置源与示波器">
								<Command Description="示波器:所有通道,@inputLevelBymV@mV档,@SourceIMPedanceName@,20MHz带宽限制" 
									InstrumentationName="GHz_MSO7000X"
									CommandType="scpi"
									SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,@DsoIMPedanceOfALLSourceAPPLySetting@,3,0,0,9,0,0"
									></Command>
								<Command Description="切到正确的交织模式"
									InstrumentationName="GHz_MSO7000X"
									CommandType="scpi"
									SCPICmd=":FACT:CHAN:ACT @OpenChannels@"
									AfterWaitSec="4"
								></Command>
								<Command Description="示波器:通道@OpenChannel@ @Bandwidth@带宽" 
									InstrumentationName="GHz_MSO7000X"
									CommandType="scpi"
									SCPICmd=":CHAN@OpenChannel@:BWL @Bandwidth@"
								></Command>
								<Command Description="信号源:频率100MHz" 
									InstrumentationName="信号源9500B"
									CommandType="scpi"
									SCPICmd="FREQuency 100000000"
									AfterWaitSec="1"
									></Command>
								<Command Description="信号源:输出电平(@SourceAmpVoltByV@V) " 
									InstrumentationName="信号源9500B"
									CommandType="scpi"
									SCPICmd="VOLTage @SourceAmpVoltByMv@"
									AfterWaitSec="1"
									></Command>	
								<Command Description="打开源1输出，用于幅度基本校准" 
									InstrumentationName="信号源9500B"
									CommandType="scpi"
									SCPICmd="OUTPut ON"
									></Command>
							</Group>
							<Command Description="模式(@InterleaveName@),档位(@inputLevelBymV@)mV,通道(@OpenChannel@),阻抗(@SourceIMPedanceName@):扫频" 
								InstrumentationName="GHz_MSO7000X"
								IsProgramFunc="true"
								ProgramFuncName="BatchTaskPart_ScanFrequency_MSO7000X @InterleaveName@,@OpenChannel@,@BatchTaskIMPedanceSetting@,@inputLevelBymV@,.\扫频频率点表\@InterleaveNameBySamplingRate@_@BatchTaskIMPedanceSetting@_@Bandwidth@.txt,AFCData\@BatchTaskIMPedanceSetting@_@Bandwidth@,GPIB0::19::INSTR"		
								ProgramFuncOverSec="40"		
							></Command>
							<Command Description="信号源:频率100MHz" 
								InstrumentationName="信号源9500B"
								CommandType="scpi"
								SCPICmd="FREQuency 100000000"
								AfterWaitSec="1"
							></Command>
						</ForeachLoop>
						<Command Description="源输出1关闭" 
							InstrumentationName="信号源9500B"
							CommandType="scpi"
							SCPICmd="OUTPut OFF"
						></Command>
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>
			<Command Description="目标示波器状态准备：系统配置:关闭数字触发、关闭DSP"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_Dsp:true"
			></Command>	
		</Task>
		<Task Description="对10G采样的数据进行抽取。" ImportanceTipMessage="该任务是对10G采样的数据进行抽取，抽取出5G和2.5G的数据">
			<ForeachLoop StartIndex="2" Count="1">
				<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1_10G,C2_10G,C3_10G,C4_10G"></VarintDefine>
				<VarintDefine name="OpenChannels"  	valuelist="C1,C2,C3,C4"></VarintDefine>
				<VarintDefine name="InterleaveNameBySamplingRate"  	valuelist="10G,10G,10G,10G"></VarintDefine>
				<VarintDefine name="ExtractScaleStart"  	valuelist="0,2,4,6"></VarintDefine>
				<VarintDefine name="ExtractScaleCount"  	valuelist="2,2,2,2"></VarintDefine>
				<ForeachLoop StartIndex="@ExtractScaleStart@" Count="@ExtractScaleCount@">
					<VarintDefine name="ExtractInterleaveName"  	valuelist="C1C2_5G,All,C1C2_5G,All,C3C4_5G,All,C3C4_5G,All"></VarintDefine>
					<VarintDefine name="ExtractBase"  	valuelist="1,1,1,1,1,1,1,1"></VarintDefine>
					<VarintDefine name="ExtractVaule"  	valuelist="2,1,2,1,2,1,2,1"></VarintDefine>					
					<VarintDefine name="ExtractInterleaveNameBySamplingRate"  	valuelist="5G,2_5G,5G,2_5G,5G,2_5G,5G,2_5G"></VarintDefine>
					<VarintDefine name="BWLChannelStart"  	valuelist="1,1,1,1,1,1,1,1"></VarintDefine>
					<VarintDefine name="BWLChannelCount"  	valuelist="1,1,1,1,1,1,1,1"></VarintDefine>
					<!--==阻抗循环==-->							
					<ForeachLoop StartIndex="1" Count="1">	
						<VarintDefine name="SourceIMPedanceName"  valuelist="50欧姆,高阻"></VarintDefine>
						<VarintDefine name="ScanFrePointTables"  valuelist="10G_LOW,10G_HIGH"></VarintDefine>
						<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
						<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
						<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
						<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>	
						<VarintDefine name="YScaleCount"  valuelist="3,3"></VarintDefine>
						<VarintDefine name="BWLStart"  valuelist="@BWLChannelStart@,0"></VarintDefine>
						<VarintDefine name="BWLCount"  valuelist="@BWLChannelCount@,1"></VarintDefine>
						<!--==带宽限制循环==-->
						<ForeachLoop StartIndex="@BWLStart@" Count="@BWLCount@">
							<VarintDefine name="Bandwidth"  valuelist="FULL,1GHz"></VarintDefine>
							<!--==挡位循环循环==-->	
							<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
								<VarintDefine name="SourceAmpVoltByMv" valuelist="0.10,0.5,3,0.20,2.0,3,10"></VarintDefine>
								<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,50,500,1000,10000"></VarintDefine>
								<Command Description="模式(@InterleaveName@),档位(@inputLevelBymV@)mV,通道(@OpenChannel@),阻抗(@SourceIMPedanceName@):扫频" 
									InstrumentationName="GHz_MSO7000X"
									IsProgramFunc="true"
									ProgramFuncName="BatchTaskPart_ExtractData AFCData\@BatchTaskIMPedanceSetting@_@Bandwidth@\@InterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,AFCData\@BatchTaskIMPedanceSetting@_@Bandwidth@\@ExtractInterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,@ExtractBase@,@ExtractVaule@"		
									ProgramFuncOverSec="40"		
								></Command>
							</ForeachLoop>
						</ForeachLoop>
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>
		</Task>	
		<Task Description="AFC500M系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的ADC平坦度校准。">
			<ForeachLoop StartIndex="6" Count="3">
				<VarintDefine name="OpenChannel"  		valuelist="1,1,1,2,2,2,3,3,3,4,4,4"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1_10G,C1C2_5G,All,C2_10G,C1C2_5G,All,C3_10G,C3C4_5G,All,C4_10G,C3C4_5G,All"></VarintDefine>
				<!--==是采样率（单位Hz)-->
				<VarintDefine name="SamplingRate"  valuelist="10e9,5e9,25e8,10e9,5e9,25e8,10e9,5e9,25e8,10e9,5e9,25e8"></VarintDefine>
				<!--==幅频补偿滤波器的阶数阶数越大，补偿精度越高-->
				<VarintDefine name="MagCompOrder"  valuelist="81,31,21,81,31,21,81,31,21,81,31,21,"></VarintDefine>
	
				<!--==频域补偿结构中的FFT点数-->
				<ConstVariantDefine name="FFTCompLen"  value="2048"></ConstVariantDefine>
				
				<!--==FPGA中的系数量化位宽 -->
				<ConstVariantDefine name="CoeQuantiBit" value="15"></ConstVariantDefine>
	
				<!--==FFT估计的长度-->
				<ConstVariantDefine name="FFTEstimationLen"  value="5e3"></ConstVariantDefine>
				
				<!--==目标频响的频率间隔-->
				<ConstVariantDefine name="FreqGap"  value="50e6"></ConstVariantDefine>
				<!--==幅度拟合精度-->
				<ConstVariantDefine name="FitSmoothingParam_Mag"  value="-"></ConstVariantDefine>
				<!--==迭代的步长-->
				<ConstVariantDefine name="StepLen"  value="-"></ConstVariantDefine>
				<!--==迭代的次数-->
				<ConstVariantDefine name="TraingTimes"  value="-"></ConstVariantDefine>
				
				<!--==第一个标识符-->
				<ConstVariantDefine name="identifier_1st"  value="-"></ConstVariantDefine>
				<!--==第二个标识符-->
				<ConstVariantDefine name="identifier_2nd"  value="-"></ConstVariantDefine>
				<!--==第一个标识符的索引-->
				<ConstVariantDefine name="identifier_1st_index"  value="-"></ConstVariantDefine>
				<!--==第二个标识符的索引-->
				<ConstVariantDefine name="identifier_2nd_index"  value="-"></ConstVariantDefine>
				<!--==补偿后幅频响应波动的最大阈值-->
				<ConstVariantDefine name="CompChekThres"  value="0.5"></ConstVariantDefine>
				<!--==补偿前100MHz以内频响波动的最大阈值-->
				<ConstVariantDefine name="InputChekThres"  value="4"></ConstVariantDefine>
				<!--==绘图标致-->
				<ConstVariantDefine name="FigureIllustrationSw"  value="OFF"></ConstVariantDefine>
	
				<!--==阻抗循环==-->
				<ForeachLoop StartIndex="1" Count="1">
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>
					<VarintDefine name="YScaleCount"  valuelist="3,3"></VarintDefine>
					<VarintDefine name="BWLStart"  valuelist="0,2"></VarintDefine>
					<VarintDefine name="BWLCount"  valuelist="2,1"></VarintDefine>
					<!--==带宽限制循环循环循环==-->	
					<ForeachLoop StartIndex="@BWLStart@" Count="@BWLCount@">
						<VarintDefine name="Bandwidth"  valuelist="FULL,1GHz,FULL,"></VarintDefine>
	
						<!--==目标频响的曲线-->
						<VarintDefine name="GoalResponseFileName"  valuelist="Response2_5G,Response1G,Response500M"></VarintDefine>
						<!--==挡位循环循环==-->
						<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
						<VarintDefine name="SourceAmpVoltByMv" valuelist="100,200,300,1100,200,800,1100,1100"></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,50,500,1000,10000"></VarintDefine>
						<!--==阻带频率（Hz）-->
						<VarintDefine name="StopBandFreq"  valuelist="3.0e9,3.0e9,2.5e9,0.8e9,0.8e9,0.8e9,0.8e9"></VarintDefine>
						<!--==通带频率（Hz）-->
						<VarintDefine name="PassBandFreq"  valuelist="2.5e9,2.5e9,2.0e9,0.8e9,0.8e9,0.8e9,0.8e9"></VarintDefine>
						<Command Description="通道@OpenChannel@ 交织模式：@InterleaveName@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@生成AFC校准数据"
							InstrumentationName="GHz_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_GenerateCoefficientsParamsByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO7000X\MatlabDLL\MatlabGenerateCoefficientsTable_AFC.dll,
							CoefficientType=AFC,
							Channel=CH@OpenChannel@,
							SaveCoefficientFileName=TimeDomainAFCCoe_@CoeQuantiBit@Bit.txt,
							SourceFiles_Path=AFCData\@BatchTaskIMPedanceSetting@_@Bandwidth@\@InterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							SourceFilesFilterPrefixName=Data_,
							DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
							DebugSaveFilePrefixName=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_@inputLevelBymV@Mv,
							@InterleaveName@,
							OtherParameter=@SamplingRate@ @MagCompOrder@ .\Resources\Merged@BatchTaskIMPedanceSetting@_@GoalResponseFileName@.txt @PassBandFreq@ @StopBandFreq@ @FFTEstimationLen@ @CoeQuantiBit@ @FFTCompLen@ @FreqGap@ @FitSmoothingParam_Mag@ @StepLen@ @TraingTimes@ @identifier_1st@ @identifier_2nd@ @identifier_1st_index@ @identifier_2nd_index@ @CompChekThres@ @InputChekThres@ @FigureIllustrationSw@"
						></Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@ 发送AFC校准数据"
							InstrumentationName="GHz_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_SendCoefficientParams 
							CoefficientType=AFC,
							CoeQuantiBit=0,
							CoefficientKey=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_@inputLevelBymV@Mv,
							SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
							SaveCoefficientPathAndFileName=TimeDomainAFCCoe.txt,
							MagCompOrder=@MagCompOrder@,"
						></Command>		
						<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@ 发送AFC校准数据"
							InstrumentationName="GHz_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_SendCoefficientParams 
							CoefficientType=AFC,
							CoeQuantiBit=@CoeQuantiBit@,
							CoefficientKey=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_@inputLevelBymV@Mv,
							SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
							SaveCoefficientPathAndFileName=TimeDomainAFCCoe_@CoeQuantiBit@Bit.txt,
							MagCompOrder=@MagCompOrder@,"
						></Command>						
					</ForeachLoop>
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>	
