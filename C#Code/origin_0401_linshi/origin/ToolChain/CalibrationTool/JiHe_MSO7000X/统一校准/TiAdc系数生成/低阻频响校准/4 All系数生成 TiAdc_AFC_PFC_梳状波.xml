<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->
<!--=======endregion 重要说明=====-->

<!--
	参数定义
	1：channel list
	2: 阻抗 HIGH LOW
	3：幅度挡 inputLevelBymV
	4：输入信号（单位mV）SourceAmpVoltBymV
	5：校准时限(单位S)
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO8000X程控校准方案" version="1.0.0.0" creator="pengbo" LastModifier="pengbo">
  <Instrumentations Description="endregion 方案中使用到的仪器的定义">
    <!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
    <Instrumentation
				Name="GHz_MSO7000X"
				Description="GHz_MSO7000X示波器"
				DriverType="VISA"
				Address="TCPIP0::DESKTOP-1853::inst0::INSTR"
				IsOurTargetDso="true"
				Timeout="0"
			></Instrumentation>
  </Instrumentations>

  <!--=======region 方案中任务列表=====-->
  <Tasks> 	
	<Task Description="PFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的上升时间和相位。">
		<ForeachLoop StartIndex="0" Count="4">
			<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
			<VarintDefine name="InterleaveName"  		valuelist="C1_10G,C2_10G,C3_10G,C4_10G"></VarintDefine>
			<!--==广谱信号的基频频率-->
			<ConstVariantDefine name="InputSignalFreqByHz"  value="10e6"></ConstVariantDefine>
			<!--==输入广谱信号的谐波频率间隔-->
			<ConstVariantDefine name="InputSignalHarmonicGapByHz"  value="10e6"></ConstVariantDefine>
			<!--==系统采样率,单位Hz-->
			<ConstVariantDefine name="SamplingRateBySps"  value="20e9"></ConstVariantDefine>
			<!--==系统带宽-->
			<ConstVariantDefine name="TagetBandwidthByhz"  value="7.5e9"></ConstVariantDefine>
			<!--==FFT估计的长度-->
			<ConstVariantDefine name="FFTEstimationNum"  value="80e3"></ConstVariantDefine>
			<!--==参考波形-->
			<ConstVariantDefine name="RefwaveFileName"  value=".\Resources\ref_1M_Domestic_10Gsps_4GHz.mat"></ConstVariantDefine>
			<!--==系数量化位宽-->
			<ConstVariantDefine name="CoeQuantiBit"  value="15"></ConstVariantDefine>
			<!--==频域补偿的长度-->
			<ConstVariantDefine name="FFTCompLen"  value="2048"></ConstVariantDefine>
			<ConstVariantDefine name="AveFocusFreq"  value="1e9"></ConstVariantDefine>
			<!--==相位拟合精度-->
			<ConstVariantDefine name="SmoothingParam_Phase"  valuelist="-"></ConstVariantDefine>
			<!--==不参与拟合的频点文件名称-->
			<ConstVariantDefine name="UnconcernedFreqFileName"  value=".\Resources\UnconcernedFreqPoints_YuZhao.txt"></ConstVariantDefine>
			<!--==FIR系数的保留精度-->
			<ConstVariantDefine name="Threshold"  value="0.5e-2"></ConstVariantDefine>
			<!--==补偿后快沿观测窗口-->
			<ConstVariantDefine name="VisualTimeRangeFileName"  value="-"></ConstVariantDefine>
			<!--==观测补偿信号后的插值倍率-->
			<ConstVariantDefine name="InterpRate"  value="-"></ConstVariantDefine>
			<!--==绘图标致-->
			<ConstVariantDefine name="FigureIllustrationSw"  value="-"></ConstVariantDefine>
			<ConstVariantDefine name="Bandwidth"  value="FULL"></ConstVariantDefine>
			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="3,4"></VarintDefine>
				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,50,500,1000,10000"></VarintDefine>
					<Command Description="生成校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientsParamsByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO7000X\MatlabDLL\MatlabGenerateCoefficientsTable_CombSignal_PFC.dll,
						CoefficientType=PFC,
						Channel=CH@OpenChannel@,
						SaveCoefficientFileName=PFC_TiadcQuantied_@CoeQuantiBit@bit.txt,
						SourceFiles_Path=PFCDataFiles,
						SourceFilesFilterPrefixName=WaveData_C@OpenChannel@_,
						DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
						DebugSaveFilePrefixName=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@,
						@InterleaveName@,
						OtherParameter=10e6 10e6 10e9 2.49e9 50e3 @RefwaveFileName@ 15 2048 1e9 - .\Resources\UnconcernedFreqFileNameC3.txt 70 - @VisualTimeRangeFileName@ 10 .txt OFF">
					</Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送PFC校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=PFC,
						CoeQuantiBit=0,
						CoefficientKey=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
						SaveCoefficientPathAndFileName=TimeDomainPFCCoe.txt,
						MagCompOrder=0"
				    ></Command>		
					<!--<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送PFC 15bit校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams
						CoefficientType=PFC,
						CoeQuantiBit=@CoeQuantiBit@,
						CoefficientKey=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
						SaveCoefficientPathAndFileName=FreqDomainPFCCoe_@CoeQuantiBit@Bit.txt,
						MagCompOrder=0"
				    ></Command>-->	
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>
	</Task>
	<Task Description="IFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的TiAdc和AFC">
		<ForeachLoop StartIndex="0" Count="4">
			<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="C1_10G,C2_10G,C3_10G,C4_10G"></VarintDefine>
			<!--==FPGA中的系数量化位宽-->
			<VarintDefine name="QuantiBitFPGA"  valuelist="15,15,15,15"></VarintDefine>
			<!--==合并的模式-->
			<VarintDefine name="MergingMode"  valuelist="AFC_PFC,AFC_PFC,AFC_PFC,AFC_PFC"></VarintDefine>
			<!--==频域补偿结构中的FFT点数-->
			<VarintDefine name="FFTCompLen"  valuelist="2048,2048,2048,2048"></VarintDefine>
			
			<!--==AFC时域滤波器系数-->
			<ConstVariantDefine name="AFCTimeCoeFileName" value="-"></ConstVariantDefine>
			<!--==PFC时域滤波器系数-->
			<ConstVariantDefine name="PFCTimeCoeFileName" value="-"></ConstVariantDefine>
			<!--==TIADC频域系数的绝对地址 -->
			<ConstVariantDefine name="TIADCFreqCoeFileName" value="-"></ConstVariantDefine>		
			<!--==绘图标致 -->
			<ConstVariantDefine name="FigureIllustrationSw" value="OFF"></ConstVariantDefine>
			<ConstVariantDefine name="Bandwidth"  value="FULL"></ConstVariantDefine>
			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="3,3"></VarintDefine>

				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="SourceAmpVoltByMv" valuelist="100,200,300,1100,200,800,1100,1100"></VarintDefine>
					<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,50,500,1000,10000"></VarintDefine>
					<!--==参数：1.dsp的key信息 2.存储系数路径 3.系数类型==-->
					<Command Description="从示波器获取AFC数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GetDSPData @InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_FULL_@inputLevelBymV@Mv,CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_FULL,AFC"
						ProgramFuncOverSec="20"
					></Command>		
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@mv 生成IFC校准数据"
								InstrumentationName="GHz_MSO7000X"
								IsProgramFunc="true"
								ProgramFuncName="BatchTaskPart_GenerateCoefficientsParamsByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO7000X\MatlabDLL\MatlabGenerateCoefficientsTable_CoeMerging.dll,
								CoefficientType=IFC,
								Channel=CH@OpenChannel@,
								SaveCoefficientFileName=@MergingMode@_TimeDomain_@QuantiBitFPGA@Bit.txt,
								SourceFiles_Path=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
								SourceFilesFilterPrefixName=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
								DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_FULL,
								DebugSaveFilePrefixName=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_FULL_@inputLevelBymV@Mv,
								@InterleaveName@,
								OtherParameter=@QuantiBitFPGA@ @MergingMode@ @FFTCompLen@ CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_FULL\AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_FULL_@inputLevelBymV@Mv_TimeDomainAFCCoe.txt CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_FULL\PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_TimeDomainPFCCoe.txt - off"
				    ></Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@mv 发送IFC校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=IFC,
						CoeQuantiBit=0,
						CoefficientKey=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_@inputLevelBymV@Mv,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
						SaveCoefficientPathAndFileName=@MergingMode@_TimeDomain.txt,
						MagCompOrder=0,"
				    ></Command>		
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 带宽限制：@Bandwidth@ 档位：@inputLevelBymV@mv 发送IFC 15bit校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=IFC,
						CoeQuantiBit=@CoeQuantiBit@,
						CoefficientKey=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@Bandwidth@_@inputLevelBymV@Mv,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@_@Bandwidth@,
						SaveCoefficientPathAndFileName=@MergingMode@_TimeDomain_@CoeQuantiBit@Bit.txt,
						MagCompOrder=0,"
				    ></Command>
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>
		<Command Description="目标示波器状态准备：系统配置:关闭数字触发、关闭DSP"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_Dsp:true"
		></Command>			
    </Task>
	<Task>
		<Command Description="保存校准数据" 
			InstrumentationName="GHz_MSO7000X"
			IsProgramFunc="true"
			ProgramFuncName="BatchTaskPart_SaveCaliDataToFile CoefficientsParams"
		></Command>
	</Task>
  </Tasks>
</InstrumentationAutoControlSolution>
