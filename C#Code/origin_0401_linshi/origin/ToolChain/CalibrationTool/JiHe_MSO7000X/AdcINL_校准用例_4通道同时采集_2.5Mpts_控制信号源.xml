<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->
<!--=======endregion 重要说明=====-->

<!--
	参数定义
	1：channel list
	2: 阻抗 HIGH LOW
	3：幅度挡 inputLevelBymV
	4：输入信号（单位mV）SourceAmpVoltBymV
	5：校准时限(单位S)
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO7000X程控校准方案" version="1.0.0.0" creator="zhaoyong" LastModifier="zhaoyong">
  <Instrumentations Description="endregion 方案中使用到的仪器的定义">

    <!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
    <Instrumentation
			Name="UTG9000T信号源"
			Description="UTG9000T信号源"
			DriverType="VISA"
			Address="USB0::0x6656::0x0834::AWG9222420005::INSTR"
			Timeout="0"
		></Instrumentation>
    <Instrumentation
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
      Address="TCPIP0::DESKTOP-1853::inst0::INSTR"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
  </Instrumentations>

  <!--=======region 方案中任务列表=====-->
  <Tasks>
    <Task Description="ADC 非线性校准" ImportanceTipMessage="该任务是通过程控来校准示波器的ADC 非线性校准。使用UTG9000T的四个通道 输出接入示波器的各个通道！">
      <Command Description="检查信号源与示波器的连接情况"
				InstrumentationName="GHz_MSO7000X"
				CommandType="check"
				SCPICmd=""
			></Command>
      
      <Command Description="信号源复位"
				InstrumentationName="GHz_MSO7000X"
				CommandType="scpi"
				SCPICmd="*RST"
			></Command>

      <ForeachLoop StartIndex="0" Count="4" Description="STEP1:UTG9000T信号源 参数设置">
       <VarintDefine name="SourceChannelID"  valuelist="1,2,3,4"></VarintDefine>        
          <Command Description="STEP1:UTG9000T信号源 参数设置"
          InstrumentationName="UTG9000T信号源"
          CommandType="scpi"
          SCPICmd=":CHANnel@SourceChannelID@:AMPLitude:UNIT VPP;:CHANnel@SourceChannelID@:BASE:AMPLitude 1;:CHANnel@SourceChannelID@:BASE:WAVe SINe;:CHANnel@SourceChannelID@:BASE:OFFSet 0;:CHANnel@SourceChannelID@:BASE:FREQuency 100000;:CHANnel@SourceChannelID@:LOAD 50;:CHANnel@SourceChannelID@:BASE:PHAse 0;:CHANnel@SourceChannelID@:OUTPut ON"
					></Command>
      </ForeachLoop>
      <Group Description="STEP2:目标示波器状态准备">

        <Command Description="STEP2.1:目标示波器状态准备：系统配置:打开数字触发、关闭FPGA 增益细调、关闭AdcINL"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_CtrlGainByFpga:false,bEnable_AdcINL:false,bEnable_AdcConditionFilter:false"
					></Command>


        <Command Description="STEP2.2:目标示波器状态准备：时基档设置为:1ms、采集模式为：普通、存储深度为25K"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":TIMebase:SCALe 100e-6"
					></Command>

        <Command Description="STEP2.3:目标示波器状态准备：触发系统:边沿触发、预触发位置0、触发模式：正常、触发电平、触发边沿"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":TRIG:TYP EDGe;:TIMebase:DELAy 0;:TRIG:MODE NORMal;:TRIG:EDG:LEV 0;:TRIG:EDG:SLOP RISE;:TRIGger:EDGe:SOURce C1"
					></Command>

        <Command Description="STEP2.4:通道设置：DC50,100mV档，20MHz带宽限制，基线居中"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":FACTory:ALLSource:APPLy 1,100,0,2,3,3,0,9,0,0"
				></Command>

        </Group>

    <Group Description="STEP3:删除原有数据并读取数据，生成校准数据">
        <Command Description="删除原始数据"
        InstrumentationName="GHz_MSO7000X"
        CommandType="scpi"
        IsProgramFunc="true"
        ProgramFuncName="BatchTaskPart_SystemCommand del AcqDataFiles\*.* /Q"
				AfterWaitSec="2"
        ></Command>

        <Command Description="停止采集"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":STOP"
				  AfterWaitSec="1"               
			  ></Command>

        <!--==通道循环,读取数据并依次生成校准数据-->
        <ForeachLoop StartIndex="0" Count="4">
        <VarintDefine name="ChannelID"  valuelist="1,2,3,4"></VarintDefine>
        <Command Description="获取采集数据"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_SaveWaveData DataLength=2500000,ChannelList=@ChannelID@,SaveFileName=AcqDataFiles\C@ChannelID@_WaveData.txt,true,100000"
				  ></Command>
		</ForeachLoop>		
		
	    <!--==通道循环-->
        <ForeachLoop StartIndex="0" Count="4">
        <VarintDefine name="ChannelID"  valuelist="1,2,3,4"></VarintDefine>
        <Command Description="生成校准数据"
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO7000X\MatlabDLL\MatlabGenerateCoefficientsTable_ADCINL.dll,CoefficientType=Coefficients2,Channel=CH@ChannelID@,SaveCoefficientFileName=DebugFiles\AdcINL_C@ChannelID@.txt,SourceFiles_Path=AcqDataFiles,SourceFilesFilterPrefixName=C@ChannelID@_WaveData,DebugSaveFilePath=DebugFiles,DebugSaveFilePrefixName=AdcINL_C@ChannelID@_,OtherParameter=0.1 2.5 - - - - 1000000 -"
				></Command>
        <Command Description="保存校准数据" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true"
          ProgramFuncName="BatchTaskPart_SaveCaliDataToFile CoefficientsTables,Coefficients2"
        ></Command>
        </ForeachLoop>
    </Group>
        
      <Group Description="STEP4:后处理，部分设置还原">
        <Command Description="打开FPGA 增益细调"
          InstrumentationName="GHz_MSO7000X"
          CommandType="scpi"
          SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_CtrlGainByFpga:true,bEnable_AdcINL:true,bEnable_AdcConditionFilter:true"
				></Command>
        <Command Description="开启采集"
         	InstrumentationName="GHz_MSO7000X"
          	CommandType="scpi"
          	SCPICmd=":RUN"
		AfterWaitSec="1"               
	></Command>			
        <ForeachLoop StartIndex="0" Count="4" Description="设置信号源：输出关闭">
          <VarintDefine name="SourceChannelID"  valuelist="1,2,3,4"></VarintDefine>
          <Command Description="设置信号源：输出打开"
          InstrumentationName="UTG9000T信号源"
          CommandType="scpi"
          SCPICmd=":CHANnel@SourceChannelID@:OUTPut OFF"
          AfterWaitSec="0.5"
					></Command>
          </ForeachLoop>
        </Group>
    </Task>
  </Tasks>
</InstrumentationAutoControlSolution>
