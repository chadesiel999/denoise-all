<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="JPO6000程控校准方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="普源信号源A"
			Description="普源信号源A"
			DriverType="VISA"
			Address="USB0::0x1AB1::0x0641::DG4C140300034::INSTR"
			
			Timeout="0"
			></Instrumentation>
			<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="JPO6000"
			Description="10G示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="检查校准通道1、2的高、低阻全档位的基线-3格及增益" ImportanceTipMessage="相关仪器、连接线等准备好了吗？"
			ExcelFile=".\Excel_4通道4G.xlsx">
			<!--===第一阶段，检查基线==========-->						
			<Command Description="现在即将对通道的基线校准进行检查，请确保4个通道的输入端口无信号输入！" 
				InstrumentationName="普源信号源A"
				CommandType="check"
				SCPICmd=""
				></Command>
			<Command Description="源输出关闭" 
				InstrumentationName="普源信号源A"
				CommandType="scpi"
				SCPICmd=":OUTPut1:STATe OFF"
				></Command>
			<Command Description="源输出关闭" 
				InstrumentationName="普源信号源A"
				CommandType="scpi"
				SCPICmd=":OUTPut2:STATe OFF"
				></Command>
				
			<Command Description="参数测量为平均值" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM1:TYP AVER"
				></Command>		
			<Command Description="参数测量为平均值" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM2:TYP AVER"
				></Command>			
			<Command Description="参数测量源" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM1:SOUR CHAN1"
				></Command>	
			<Command Description="参数测量源" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM2:SOUR CHAN2"
				></Command>
			
			<Command Description="时基档500us" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":TIM:SCAL 0.0005"
				></Command>	
			<Group Description="高阻">
				<Group Description="Step1:基线检查">
				<ForeachLoop StartIndex="0" Count="13">
				<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500,200,100,50,20,10, 5, 2, 1"></VarintDefine>
				<VarintDefine name="Excel_Channel1" valuelist="B4 ,B5 ,   B6,   B7, B8, B9,B10,B11,B12,B13,B14,B15,B16"></VarintDefine>
                <VarintDefine name="Excel_Channel2" valuelist="C4 ,C5 ,   C6,   C7, C8, C9,C10,C11,C12,C13,C14,C15,C16"></VarintDefine>				
				<Command Description="所有通道,高阻@DsoYScale@mV档" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,0,0,0,0,0,0,0,0"
				AfterWaitSec="3"
				></Command>		
				<Command Description="高阻Ch1基线" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM1:VAL ?"
				BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
				BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
				></Command>	
                <Command Description="高阻Ch2基线" 
				InstrumentationName="JPO6000"
				CommandType="scpi"
				SCPICmd=":MEAS:ITEM2:VAL ?"
				BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
				BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
				></Command>					
				</ForeachLoop>	
				</Group>
				<Group Description="Step2:三格检查">
                    <ForeachLoop StartIndex="0" Count="13">
					<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500, 200,100, 50, 20,10, 5,2,  1"></VarintDefine>
					<VarintDefine name="Excel_Channel1" valuelist="B18    ,B19,  B20,  B21,  B22,B23, B24, B25,B26,B27,B28,B29,B30"></VarintDefine>
					<VarintDefine name="Excel_Channel2" valuelist="C18    ,C19,  C20,  C21,  C22,C23, C24, C25,C26,C27,C28,C29,C30"></VarintDefine>
					<Command Description="所有通道,高阻@DsoYScale@mV档" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,3000,0,0,0,0,0,0,0"
					AfterWaitSec="3"
					></Command>		
					<Command Description="高阻CH1三格" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM1:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
					></Command>	
                    <Command Description="高阻CH2三格" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM2:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
					></Command>					
                    </ForeachLoop>					
			    </Group>	
			</Group>
				
			<!--===低阻==========-->		
			<Group Description="基线-低阻">
				<ForeachLoop StartIndex="3" Count="10">
					<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500,200,100,50,20,10, 5, 2, 1"></VarintDefine>
					<VarintDefine name="Excel_Channel1" valuelist="H4,H5 ,   H6,   H7, H8,  H9, H10,H11,H12,H13,H14,H15,H16"></VarintDefine>
                    <VarintDefine name="Excel_Channel2" valuelist="I4,I5 ,   I6,   I7, I8,  I9, I10,I11,I12,I13,I14,I15,I16"></VarintDefine>					
					<Command Description="所有通道, 低阻阻@DsoYScale@mV档" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,0,2,0,0,0,0,0,0"
					AfterWaitSec="3"
					></Command>		
					<Command Description="低阻Ch1基线" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM1:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
					></Command>
                    <Command Description="低阻Ch2基线" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM2:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
					></Command>					
			    </ForeachLoop>		
			</Group>
			
			<Group Description="Step2:低阻三格检查">
				<ForeachLoop StartIndex="3" Count="10">
					<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500, 200,100, 50,20,10, 5, 2, 1"></VarintDefine>
					<VarintDefine name="Excel_Channel1" valuelist="H18  , H19, H20,H21, H22,H23,H24,H25,H26,H27,H28,H29,H30"></VarintDefine>
					<VarintDefine name="Excel_Channel2" valuelist="I18  , I19, I20,I21, I22,I23,I24,I25,I26,I27,I28,I29,I30"></VarintDefine>
					<Command Description="所有通道,高阻@DsoYScale@mV档" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,3000,2,0,0,0,0,0,0"
					AfterWaitSec="3"
					></Command>		
					<Command Description="低阻ch1三格" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM1:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
					></Command>	
                    <Command Description="低阻ch2三格" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM2:VAL ?"
					BooleanCheckFormula="Math.Abs(@result)*1000/@DsoYScale@*320 &lt; 32"
					BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
					></Command>						
				</ForeachLoop>											
			</Group>
      			
			<Group Description="Step3：幅度检查">
				<Command Description="请将信号源的两个输入接入到2个通道上。" 
					InstrumentationName="普源信号源A"
					CommandType="check"
					SCPICmd=""
					></Command>
				<Command Description="参数1测量为幅度值" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM1:TYP AMPL"
					></Command>		
				<Command Description="参数2测量为幅度值" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEAS:ITEM2:TYP AMPL"
					></Command>		
				<Command Description="打开源1输出，用于幅度检查" 
					InstrumentationName="普源信号源A"
					CommandType="scpi"
					SCPICmd="OUTPut1:STATe ON"
					></Command>
				<Command Description="打开源2输出，用于幅度检查" 
					InstrumentationName="普源信号源A"
					CommandType="scpi"
					SCPICmd=":OUTPut2:STATe ON"
					></Command>	
				
			    <Group Description="幅度检查-高阻">
					<Command Description="源OUTPut1:高阻欧姆" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":OUTPut1:IMPedance INFINITY"
						></Command>
					<Command Description="源OUTPut2:高阻欧姆" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":OUTPut2:IMPedance INFINITY"
						></Command>		
                    <Command Description="所有通道,高阻10V档" 
						InstrumentationName="JPO6000"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,10000,0,0,0,0,0,0,0,0"
						AfterWaitSec="2"
						></Command>						
					<ForeachLoop StartIndex="0" Count="13">
						<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500, 200,100, 50,  20,  10,   5,    2,   1"></VarintDefine>
						<VarintDefine name="AmpByV"       valuelist="20   , 20  ,  12,  6,   3, 1.2,0.6,0.3,0.12,0.06,0.03,0.012,0.006"></VarintDefine>
						<VarintDefine name="Excel_Channel1" valuelist="B32   ,  B33, B34,  B35,  B36, B37, B38,  B39,  B40,  B41,   B42, B43,B44"></VarintDefine>
						<VarintDefine name="Excel_Channel2" valuelist="C32   ,  C33, C34,  C35,  C36, C37, C38,  C39,  C40,  C41,   C42, C43,C44"></VarintDefine>
						
						<Command Description="源输出1:1K,@AmpByV@V" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":SOURce1:APPLy:SQUare 1000,@AmpByV@,0.0,0"
						></Command>
						<Command Description="源输出2:1K,@AmpByV@V" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":SOURce2:APPLy:SQUare 1000,@AmpByV@,0.0,0"
						></Command>
						<Command Description="所有通道,高阻@DsoYScale@mV档" 
						InstrumentationName="JPO6000"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,0,0,0,0,0,0,0,0"
						AfterWaitSec="3"
						></Command>			
						<Command Description="幅度检查-CH1-@DsoYScale@mV" 
							InstrumentationName="JPO6000"
							CommandType="scpi"
							SCPICmd=":MEAS:ITEM1:VAL ?"
							BooleanCheckFormula="Math.Abs(@result-@AmpByV@)/@AmpByV@ &lt; 0.005"
							BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
						></Command>	
						<Command Description="幅度检查-CH2-@DsoYScale@mV"
							InstrumentationName="JPO6000"
							CommandType="scpi"
							SCPICmd=":MEAS:ITEM2:VAL ?"
							BooleanCheckFormula="Math.Abs(@result-@AmpByV@)/@AmpByV@ &lt; 0.005"
							BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
						></Command>	
					</ForeachLoop>	
				</Group>
			    <Group Description="Step3：低阻幅度检查">
					<Command Description="源OUTPut1:50欧姆" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":OUTPut1:IMPedance 50"
						></Command>
					<Command Description="源OUTPut2:50欧姆" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":OUTPut2:IMPedance 50"
						></Command>		
                    <Command Description="所有通道,低阻1V档" 
						InstrumentationName="JPO6000"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,1000,0,2,0,0,0,0,0,0"
						AfterWaitSec="3"
						></Command>						
					<ForeachLoop StartIndex="3" Count="10">
						<VarintDefine name="DsoYScale"     valuelist="10000,5000,2000,1000,500, 200,100, 50,  20,  10,   5,    2,   1"></VarintDefine>
						<VarintDefine name="AmpByV"       valuelist="20   , 20  ,  12,  6,   3, 1.2,0.6,0.3,0.12,0.06,0.03,0.012,0.006"></VarintDefine>
						<VarintDefine name="Excel_Channel1" valuelist=" H32   ,  H33, H34,  H35,  H36, H37, H38,  H39,  H40,  H41,   H42, H43,H44"></VarintDefine>	
						<VarintDefine name="Excel_Channel2" valuelist=" I32   ,  I33, I34,  I35,  I36, I37, I38,  I39,  I40,  I41,   I42, I43,I44"></VarintDefine>	
						<Command Description="源输出1:1K,@AmpByV@V" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":SOURce1:APPLy:SQUare 1000,@AmpByV@,0.0,0"
						></Command>
						<Command Description="源输出2:1K,@AmpByV@V" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":SOURce2:APPLy:SQUare 1000,@AmpByV@,0.0,0"
						></Command>
						<Command Description="所有通道,低阻@DsoYScale@mV档" 
						InstrumentationName="JPO6000"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,0,2,0,0,0,0,0,0"
						AfterWaitSec="3"
						></Command>			
						<Command Description="幅度检查-CH1-@DsoYScale@mV" 
							InstrumentationName="JPO6000"
							CommandType="scpi"
							SCPICmd=":MEAS:ITEM1:VAL ?"
							BooleanCheckFormula="Math.Abs(@result-@AmpByV@)/@AmpByV@ &lt; 0.005"
							BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel1@"
						></Command>	
						<Command Description="幅度检查-CH2-@DsoYScale@mV"
							InstrumentationName="JPO6000"
							CommandType="scpi"
							SCPICmd=":MEAS:ITEM2:VAL ?"
							BooleanCheckFormula="Math.Abs(@result-@AmpByV@)/@AmpByV@ &lt; 0.005"
							BooleanCheckResultWriteAtExcelCell="基线幅度检查!@Excel_Channel2@"
						></Command>	
						
					</ForeachLoop>			
			    </Group>
            </Group>				
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>
