<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JiHe_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->
<!--
	参数定义
	[0]: 外触发通道(Ext,Ext5,);
	[1]: 高低阻(High1M,Low50,)
	[2]: 耦合方式(DC,AC,LFR,HFR,)
	[3]: 信号幅度,单位Mv
	[4]: 误差阈值,单位Uv
	[5]: 信号源地址
-->
<InstrumentationAutoControlSolution SolutionDescription="JiHe_MSO7000X程控校准方案" version="1.0.0.0" creator="王昌杰" LastModifier="zhaoyong">
	
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="普源信号源A"
			Description="普源信号源A"
			DriverType="VISA"
			Address="USB0::0x1AB1::0x0641::DG4E183302205::INSTR"
			Timeout="0"
			></Instrumentation>
			<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="JiHe_MSO7000X"
			Description="JiHe_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准外触发通道的比较电平" ImportanceTipMessage="该任务是通过程控来校准示波器的外触发通道的比较电平。">
			<Command Description="检查信号普源源与示波器外触发通道的连接情况" 
				InstrumentationName="普源信号源A"
				CommandType="check"
				SCPICmd=""
			></Command>
			<Command Description="源输出1打开" 
				InstrumentationName="普源信号源A"
				CommandType="scpi"
				SCPICmd=":OUTPut1:STATe ON"
			></Command>
			<!--==外触发通道循环-->	
			<ForeachLoop StartIndex="0" Count="2">	
				<VarintDefine name="ParamChannelId"  valuelist="Ext,Ext5"></VarintDefine>
				<ConstVariantDefine name="ParamAmpByMv" value="1000"></ConstVariantDefine>
				<ConstVariantDefine name="SourceAmpByV" value="1"></ConstVariantDefine>
				<ConstVariantDefine name="ParamErrThreshByUv" value="1000"></ConstVariantDefine>
				<ConstVariantDefine name="ParamSrcAddr" value="USB0::0x1AB1::0x0641::DG4E183302205::INSTR"></ConstVariantDefine>
				<Command Description="现在即将对外触发通道@ParamChannelId@进行校准，请确保将信号源的输出接入到通道！" 
					InstrumentationName="JiHe_MSO7000X"
					CommandType="scpi"
					SCPICmd=":TRIG:EDG:SOUR @ParamChannelId@"
				></Command>
				<!--==阻抗循环==-->							
				<ForeachLoop StartIndex="0" Count="2">
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,INFinity"></VarintDefine>
					<VarintDefine name="ParamTriggerImpedance"  valuelist="Low50,High1M"></VarintDefine>
					<VarintDefine name="CouplingCount"  valuelist="1,4"></VarintDefine>
					<Command Description="源OUTPut1:@ParamTriggerImpedance@" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":OUTPut1:IMPedance @SourceIMPedanceSetting@"
					></Command>
					<Command Description="源输出1:1k,@ParamAmpByMv@Mv" 
						InstrumentationName="普源信号源A"
						CommandType="scpi"
						SCPICmd=":SOURce1:APPLy:SQUare 1000,@SourceAmpByV@,0.0,0"
					></Command>
					<Command Description="外触发通道阻抗:@ParamTriggerImpedance@" 
						InstrumentationName="JiHe_MSO7000X"
						CommandType="scpi"
						SCPICmd=":TRIG:EDG:EXT:IMP @SourceIMPedanceSetting@"
					></Command>
					<!--==耦合方式循环==-->	
					<ForeachLoop StartIndex="0" Count="@CouplingCount@">
						<VarintDefine name="ParamTriggerCoupling"  valuelist="DC,AC,LFR,HFR"></VarintDefine>
						<Command Description="外触发通道耦合方式:@ParamTriggerCoupling@" 
							InstrumentationName="JiHe_MSO7000X"
							CommandType="scpi"
							SCPICmd=":TRIG:EDG:COUP @ParamTriggerCoupling@"
						></Command>
						<Command Description="外触发通道@ParamChannelId@、@ParamTriggerImpedance@、@ParamTriggerCoupling@触发电平校准" 
							InstrumentationName="JiHe_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_ExtTrigger @ParamChannelId@,@ParamTriggerImpedance@,@ParamTriggerCoupling@,
											@ParamAmpByMv@,@ParamErrThreshByUv@,@ParamSrcAddr@"	
							ProgramFuncOverSec="40"		
						></Command>	
					</ForeachLoop>			
		  		</ForeachLoop>
			</ForeachLoop>		  	
			<Command Description="保存校准数据" 
						InstrumentationName="JiHe_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannel"
			></Command>
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>