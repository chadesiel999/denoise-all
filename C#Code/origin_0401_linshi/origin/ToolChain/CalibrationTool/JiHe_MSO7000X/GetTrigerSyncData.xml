<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="Afc扫频方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="对各个通道，阻抗，垂直档位，进行触发同步数据采集。" ImportanceTipMessage="该任务是通过程控来对各个通道，阻抗，垂直档位，进行触发同步数据采集。">
			<Group Description="信号源及示波器控制">
				<Command Description="检查信号源与示波器的连接情况" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="采集触发同步数据" 
					InstrumentationName="GHz_MSO7000X"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_MSO7000X_TriggerSync TCPIP0::10.0.13.131::inst0::INSTR|TCPIP0::10.0.13.135::inst0::INSTR,
					30,1,TriggerData,USB0::0x6656::0x0834::AWG9222420005::INSTR"
					ProgramFuncOverSec="40"		
				></Command>
			</Group>	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>