<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="TiADC程控验证方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB4::19::INSTR"
			Timeout="0"
		></Instrumentation>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准各交织方式下各通道TiAdc" ImportanceTipMessage="该任务是通过程控来校准示波器的各交织方式下各通道TiAdc。">
			<Group Description="信号源及示波器控制">
				<Command Description="检查信号源与示波器的连接情况" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="信号源复位" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="*RST"
				></Command>
				<Command Description="设置通道1输出波形" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUTe:SIGNal CH1"
				></Command>
				<Command Description="输出波形选择正弦波" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SCOpe SIN"
				></Command>
				
				<Command Description="设置时基到实时档（1us/div）"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 0.000001"
				></Command>
				<Command Description="打开正常采集模式" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe NORMal"
				></Command>
			</Group>	
			<Command Description="STEP2.1:目标示波器状态准备：系统配置:关闭数字触发、关闭DSP"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:false,bEnable_Dsp:false"
			></Command>
			<Command Description="STEP2.1:目标示波器状态准备：系统配置:关闭数字触发、关闭DSP"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_Dsp:true"
			></Command>	
			<ForeachLoop StartIndex="0" Count="8">	
				<VarintDefine name="OpenChannel"  		valuelist="1		,1		,2		,2		,3		,3		,4		,4		"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C2_5G	,C1_10G	,C1C2_5G,C2_10G	,C3C4_5G,C3_10G	,C3C4_5G,C4_10G	"></VarintDefine>
				<Group Description="常量设置">
					<ConstVariantDefine name="HardwareValidMs_TiAdc" value="200"></ConstVariantDefine>
					<ConstVariantDefine name="NeedStaticTimes_TiAdc" value="1"></ConstVariantDefine>
					<ConstVariantDefine name="TotalErrorByPercent_TiAdc" value="15"></ConstVariantDefine>
					<ConstVariantDefine name="DSAStepPercent_TiAdc" value="12.2"></ConstVariantDefine>
					<ConstVariantDefine name="ADCStepPercent_TiAdc" value="0.06"></ConstVariantDefine>
					<ConstVariantDefine name="FPGAYLevelID_TiAdc" value="1"></ConstVariantDefine>
					<ConstVariantDefine name="DSACtrlWord_TiAdc" value="0,32" Description="包含两个参数"></ConstVariantDefine>
					<ConstVariantDefine name="ADCCtrlWord_TiAdc" value="0,255"></ConstVariantDefine>
					<ConstVariantDefine name="FpgaCtrlWord_TiAdc" value="200,5000"></ConstVariantDefine>
					<ConstVariantDefine name="AmpMeasureType_TiAdc" value="AMPL"></ConstVariantDefine>
				</Group>
				
				<Command Description="现在即将对 “通道 (@OpenChannel@) ” 进行校准，请确保将信号源的输出接入到相应的通道！" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>

				<!--==阻抗循环==-->							
				<ForeachLoop StartIndex="0" Count="2">	
					<VarintDefine name="SourceIMPedanceName"  valuelist="50欧姆,高阻"></VarintDefine>
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="SourceFrequencyByMhz"  valuelist="1000,500"></VarintDefine>	
					<VarintDefine name="YScaleCount"  valuelist="10,14"></VarintDefine>	
					<Command Description="信号源:阻抗(@SourceIMPedanceName@) " 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="ROUT:SIGN:IMP @SourceIMPedanceSetting@"
						></Command>
					<Command Description="设置信号源输出频率为1G" 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="FREQuency @SourceFrequencyByMhz@E6"
					></Command>
					<!--==挡位循环循环==-->	
					<ForeachLoop StartIndex="1" Count="@YScaleCount@">
						<VarintDefine name="SourceAmpVoltByV" valuelist="0.003,0.006,0.012   ,0.03    ,0.06    ,0.12    ,0.3     ,0.6     ,1.2     ,3       ,5       ,6,12      ,30      ,60      "></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="0.5  ,1    ,2       ,5       ,10      ,20      ,50      ,100     ,200     ,500     ,1000    ,1000,2000    ,5000    ,10000   "></VarintDefine>
						<Group Description="设置源与示波器">
							<Command Description="示波器:所有通道,@inputLevelBymV@mV档,@SourceIMPedanceName@,20MHz带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,@DsoIMPedanceOfALLSourceAPPLySetting@,3,0,0,9,0,0"
								></Command>
								<Command Description="切到正确的交织模式" 
									InstrumentationName="GHz_MSO7000X"
									CommandType="scpi"
									SCPICmd=":FACT:CHAN:ACT @InterleaveName@"
								></Command>
							<Command Description="示波器:通道@OpenChannel@ 1G 带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHAN@OpenChannel@:BWL 1G"
								></Command>
							<Command Description="信号源:输出电平(@SourceAmpVoltByV@V) " 
								InstrumentationName="信号源9500B"
								CommandType="scpi"
								SCPICmd="VOLTage @SourceAmpVoltByV@"
								AfterWaitSec="1"
								></Command>	
							<Command Description="打开源1输出，用于幅度基本校准" 
								InstrumentationName="信号源9500B"
								CommandType="scpi"
								SCPICmd="OUTPut ON"
							></Command>
						</Group>

						<Command Description="模式(@InterleaveName@),通道(@OpenChannel@):Tiadc校准" 
							InstrumentationName="GHz_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_TiAdc_JiHe_MSO7000X_Test @InterleaveName@,@OpenChannel@,5,@BatchTaskIMPedanceSetting@,@inputLevelBymV@,@SourceFrequencyByMhz@,2500,0.3,0.4,0.8"	
							ProgramFuncOverSec="40"		
							></Command>
						<Command Description="源输出1打开" 
							InstrumentationName="信号源9500B"
							CommandType="scpi"
							SCPICmd="OUTPut OFF"
							></Command>
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>