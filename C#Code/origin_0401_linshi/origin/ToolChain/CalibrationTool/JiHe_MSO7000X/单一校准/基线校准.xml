<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JiHe_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->
<!--
	参数定义
	//[0]其中1|2 表示通道，编号从1开始；
	//[1]表示高阻还是低阻，low=50欧姆，低阻，higf表示高阻。
	//[2]以mV为单位的档位值，浮点数
	//[3]0格或3格
	//[4]通道最小粗调值
	//[5]通道最大粗调值
	//[6]调节步进值
	//[7]总体误差判据，百分比表示 
	//[8]统计次数
	//[9]校准数据生效时间，用ms表示
	//[10]最大超时时间，用s表示
	//[11]:是否计算步进
	//[12]:Delta:3Div阈值,8G通道专用
-->
<InstrumentationAutoControlSolution SolutionDescription="JiHe_MSO7000X程控校准方案" version="1.0.0.0" creator="王昌杰" LastModifier="zhaoyong">

	<Instrumentations Description="使用的仪器">
		<Instrumentation Name="JiHe_MSO7000X" Description="JiHe_MSO7000X示波器" DriverType="VISA" IsOurTargetDso="true" Timeout="0" />
	</Instrumentations>
	
	<Tasks Description="任务列表">
		<Task Description="校准通道高阻、低阻全档位基线" ImportanceTipMessage="该任务是通过程控来校准示波器的通道基线。">

			<Group Description="示波器通道设置">
				<Command Description="时基档1ms" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" 
					SCPICmd=":TIM:SCAL 0.0002"/>
				<Command Description="打开高分辨率模式"  InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
					SCPICmd=":ACQuire:TYPe HIGHres" />
				<Command Description="存储深度：25K" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:STOR Of25KDots"
					></Command>
				<Command Description="现在即将对通道基线进行校准，请确保将无输入信号接入通道！" InstrumentationName="JiHe_MSO7000X" CommandType="check"
					SCPICmd="" />
			</Group>

			<ForeachLoop Description="低阻" StartIndex="2" Count="9">
				<VarintDefine name="inputLevelBymV"  		valuelist="0.5 ,1   ,2   ,5   ,10  ,20  ,50  ,100 ,200 ,500 ,1000,2000 ,5000,10000"></VarintDefine>
				<VarintDefine name="Step"  					valuelist="50  ,50  ,50  ,50  ,100 ,100 ,100 ,100 ,100 ,100 ,100 ,100  ,100 ,100  "></VarintDefine>
				<VarintDefine name="TotalErrorByPercent"  	valuelist="2   ,0.5   ,0.5   ,0.5   ,0.5  ,0.5  ,0.5   ,0.5   ,0.5   ,0.5  ,0.5   ,0.5    ,0.5   ,0.5    "></VarintDefine>
				<VarintDefine name="Delta"  				valuelist="8000,8500,8400,8100,7600,6800,7000,5500,6500,7600,6500,10500,9000,7000 "></VarintDefine>

				<Group Description="示波器通道设置">
					<Command Description="所有通道,@inputLevelBymV@mV档,低阻,20MHz带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" AfterWaitSec="2"
							SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,2,3,0,0,9,0,0" />
					
					<Command Description="通道1 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN1:BWL 20MHz" />
					<Command Description="通道2 20MHz 带宽限制"  InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN2:BWL 20MHz"/>
					<Command Description="通道3 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" 
						SCPICmd=":CHAN3:BWL 20MHz"/>
					<Command Description="通道4 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN4:BWL 20MHz"/>
				</Group>

				<Command Description="@inputLevelBymV@mV档、低阻:基线0Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="30"	
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,0,0,20000,@Step@,@TotalErrorByPercent@,5,500,40,true"/>	
				<Command Description="@inputLevelBymV@mV档、低阻:基线3Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="30"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,3,0,10000,@Step@,@TotalErrorByPercent@,5,500,40,false"/>
				<Command Description="@inputLevelBymV@mV档、低阻:基线-3Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="30"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,-3,0,10000,@Step@,@TotalErrorByPercent@,5,500,40,false"/>
			</ForeachLoop>
			
			<ForeachLoop Description="高阻" StartIndex="2" Count="12">
				<VarintDefine name="inputLevelBymV"  			valuelist="0.5 ,1   ,2   ,5   ,10  ,20  ,50  ,100 ,200 ,500 ,1000,2000 ,5000,10000"></VarintDefine>
				<VarintDefine name="Step"  								valuelist="50  ,50  ,50  ,50  ,100 ,100 ,100 ,100 ,100 ,100 ,100 ,100  ,100 ,100  "></VarintDefine>
				<VarintDefine name="TotalErrorByPercent"  valuelist="3   ,0.5    ,0.5    ,0.5    ,0.5    ,0.5   ,0.5    ,0.5    ,0.5    ,0.5    ,0.5    ,0.5    ,0.5    ,0.5     "></VarintDefine>
				<VarintDefine name="Delta"  							valuelist="8000,8500,8400,8100,7600,6800,7000,5500,6500,7600,6500,10500,9000,7000 "></VarintDefine>
				
				<Group Description="示波器通道设置">
					<Command Description="所有通道,@inputLevelBymV@mV档,高阻,20MHz带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" AfterWaitSec="1"
						SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,0,3,0,0,9,0,0"/>
					<Command Description="通道1 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN1:BWL 20MHz" />
					<Command Description="通道2 20MHz 带宽限制"  InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN2:BWL 20MHz"/>
					<Command Description="通道3 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" 
						SCPICmd=":CHAN3:BWL 20MHz"/>
					<Command Description="通道4 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi"
						SCPICmd=":CHAN4:BWL 20MHz"/>
				</Group>
						
				<Command Description="@inputLevelBymV@mV档、高阻:基线0Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="20"	
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,HIGH,@inputLevelBymV@,0,0,50000,@Step@,@TotalErrorByPercent@,5,600,40,true"/>
				<Command Description="@inputLevelBymV@mV档、高阻:基线3Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="20"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,HIGH,@inputLevelBymV@,3,0,10000,@Step@,@TotalErrorByPercent@,5,600,40,false"/>
				<Command Description="@inputLevelBymV@mV档、高阻:基线-3Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncOverSec="20"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,HIGH,@inputLevelBymV@,-3,0,10000,@Step@,@TotalErrorByPercent@,5,600,40,false"/>
			</ForeachLoop>	
			
			<Command Description="读取设置基线校准完成后通道温度" InstrumentationName="GHz_MSO7000X" IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SetAnalogChannelTemperatue BaseLine" />
			<Command Description="保存校准数据" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannel" />	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>