<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="TiADC程控校准方案" version="1.0.0.0" creator="王昌杰" LastModifier="zhaoyong">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB0::19::INSTR"
			Timeout="0"
		></Instrumentation>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准各交织方式下各通道TiAdc" ImportanceTipMessage="该任务是通过程控来校准示波器的各交织方式下各通道TiAdc。">
			<Group Description="信号源及示波器控制">
				<Command Description="检查信号源与示波器的连接情况" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="信号源复位" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="*RST"
					AfterWaitSec="2"
				></Command>
				<Command Description="设置通道1输出波形" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUTe:SIGNal CH1"
				></Command>
				<Command Description="输出波形选择正弦波" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SCOpe SIN"
				></Command>
				<Command Description="设置信号源输出频率为1G" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="FREQuency 1E9"
				></Command>
				<Command Description="信号源:低阻" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="ROUT:SIGN:IMP 50"
					></Command>
				<Command Description="设置信号源输出幅度" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="VOLTage 0.25"
				></Command>
				
				<Command Description="设置时基到实时档（1us/div）"
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 0.000001"
				></Command>
				<Command Description="打开正常采集模式" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe NORMal"
				></Command>
			</Group>	

			<ForeachLoop StartIndex="6" Count="2">	
				<VarintDefine name="OpenChannel"  		valuelist="1		,1		,2		,2		,3		,3		,4		,4		"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C2_5G	,C1_10G	,C1C2_5G,C2_10G	,C3C4_5G,C3_10G	,C3C4_5G,C4_10G	"></VarintDefine>
				<Group Description="常量设置">
					<ConstVariantDefine name="HardwareValidMs_TiAdc" value="200"></ConstVariantDefine>
					<ConstVariantDefine name="NeedStaticTimes_TiAdc" value="1"></ConstVariantDefine>
					<ConstVariantDefine name="TotalErrorByPercent_TiAdc" value="15"></ConstVariantDefine>
					<ConstVariantDefine name="DSAStepPercent_TiAdc" value="12.2"></ConstVariantDefine>
					<ConstVariantDefine name="ADCStepPercent_TiAdc" value="0.06"></ConstVariantDefine>
					<ConstVariantDefine name="FPGAYLevelID_TiAdc" value="1"></ConstVariantDefine>
					<ConstVariantDefine name="DSACtrlWord_TiAdc" value="0,32" Description="包含两个参数"></ConstVariantDefine>
					<ConstVariantDefine name="ADCCtrlWord_TiAdc" value="0,255"></ConstVariantDefine>
					<ConstVariantDefine name="FpgaCtrlWord_TiAdc" value="200,5000"></ConstVariantDefine>
					<ConstVariantDefine name="AmpMeasureType_TiAdc" value="AMPL"></ConstVariantDefine>
				</Group>

				<Command Description="现在即将对 “通道 (@OpenChannel@) ” 进行校准，请确保将信号源的输出接入到相应的通道！" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Group Description="示波器校准基线和幅度">
					<Command Description="所有通道,50mV档,低阻" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,50,0,2,1,0,0,9,0,0"
						></Command>
					<Command Description="存储深度：25K" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":FACT:STOR Of25KDots"
						></Command>
					<Command Description="通道1 1GHz 带宽限制" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":CHAN1:BWL 1GHz"
						></Command>
					<Command Description="通道2 1GHz 带宽限制" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":CHAN2:BWL 1GHz"
						></Command>
					<Command Description="通道3 1GHz 带宽限制" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":CHAN3:BWL 1GHz"
						></Command>
					<Command Description="通道4 1GHz 带宽限制" 
						InstrumentationName="GHz_MSO7000X"
						CommandType="scpi"
						SCPICmd=":CHAN4:BWL 1GHz"
						></Command>
					<Command Description="关闭源1输出，用于基线基本校准" 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="OUTPut OFF"
					></Command>

					<Command Description="通道 “@OpenChannel@” ，低阻档，50mv档:基线0Div校准" 
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_CaliChannelBaseLine @OpenChannel@,LOW,50,0,0,20000,100,10,5,400,20,true"	
						ProgramFuncOverSec="20"		
					></Command>	

					<Command Description="打开源1输出，用于幅度基本校准" 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="OUTPut ON"
					></Command>
					<Command Description="通道 “@OpenChannel@” ，低阻档，50mv档:幅度校准" 
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_CaliChannelGain @OpenChannel@,LOW,50,0.25,Dsa_Adc_Fpga,@HardwareValidMs_TiAdc@,@NeedStaticTimes_TiAdc@,@TotalErrorByPercent_TiAdc@
												,@DSAStepPercent_TiAdc@,@ADCStepPercent_TiAdc@,@FPGAYLevelID_TiAdc@,@DSACtrlWord_TiAdc@,@ADCCtrlWord_TiAdc@,@FpgaCtrlWord_TiAdc@,@AmpMeasureType_TiAdc@"	
						ProgramFuncOverSec="40"		
						></Command>	
				</Group>
				<Command Description="模式(@InterleaveName@),通道(@OpenChannel@):Tiadc校准" 
					InstrumentationName="GHz_MSO7000X"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_TiAdc_JiHe_MSO7000X @InterleaveName@,@OpenChannel@,Low,50,1000,2500,0.15,0.3,600,5"	
					ProgramFuncOverSec="80"		
					></Command>
				<Command Description="源输出1打开" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="OUTPut OFF"
					></Command>
			</ForeachLoop>
			<Command Description="保存校准数据" 
					InstrumentationName="GHz_MSO7000X"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_SaveCaliDataToFile TiAdc_PhaseOffsetGain_JiHe_MSO7000X"
			></Command>	
			<Command Description="保存校准数据" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannel" />	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>