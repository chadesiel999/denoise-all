<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->
<!--=======endregion 重要说明=====-->

<!--
	参数定义
	1：channel list
	2: 阻抗 HIGH LOW
	3：幅度挡 inputLevelBymV
	4：输入信号（单位mV）SourceAmpVoltBymV
	5：校准时限(单位S)
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO7000X程控校准方案" version="1.0.0.0" creator="王昌杰" LastModifier="zhaoyong">
	<Instrumentations Description="endregion 方案中使用到的仪器的定义">
		<Instrumentation 
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB0::19::INSTR"
			Timeout="0"
			></Instrumentation>
		
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO7000X"
			Description="GHz_MSO7000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>

	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准通道的低阻(20mv,100mv,1v)、高阻(50mv,500mv,1v,10v)的偏执" ImportanceTipMessage="该任务是通过程控来校准示波器的偏执。">
			<Command Description="检查信号源与示波器的连接情况" 
				InstrumentationName="信号源9500B"
				CommandType="check"
				SCPICmd=""
				></Command>

			<Group Description="示波器及信号源初始化">
				<Command Description="时基档1us" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 0.001"
					></Command>	
				<Command Description="打开高分辨率模式" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe HIGHres"
					></Command>
				<Command Description="存储深度：25K" 
					InstrumentationName="GHz_MSO7000X"
					CommandType="scpi"
					SCPICmd=":FACT:STOR Of25KDots"
					></Command>
				<Command Description="源复位" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="*RST"
					AfterWaitSec="2"
					></Command>
				<Command Description="源输出电压模式" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="SCOpe DC"
					></Command>
			</Group>

			<!--==通道循环-->	
			<ForeachLoop StartIndex="0" Count="4">	
				<VarintDefine name="Channel"  valuelist="1,2,3,4"></VarintDefine>
				<Command Description="现在即将对 “通道@Channel@” 进行校准，请确保将信号源的输出接入到通道！" 
						InstrumentationName="信号源9500B"
						CommandType="check"
						SCPICmd=""
				></Command>
				<!--==阻抗循环==-->							
				<ForeachLoop StartIndex="0" Count="2">	
					<VarintDefine name="SourceIMPedanceName"  valuelist="50欧姆,高阻"></VarintDefine>
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>	
					<VarintDefine name="YScaleCount"  valuelist="3,4"></VarintDefine>	
					<Command Description="源OUTPut1:@SourceIMPedanceName@" 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="ROUT:SIGN:IMP @SourceIMPedanceSetting@"
						></Command>
					<!--==挡位循环循环==-->	
					<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
						<VarintDefine name="SourceAmpVoltByV" valuelist="2	,2	,5		,2 	,20	,40		,80	"></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="20	,100,1000	,50	,500,1000	,10000 	"></VarintDefine>

						<Group Description="示波器通道设置">
							<Command Description="所有通道,@inputLevelBymV@mV档,@SourceIMPedanceName@,20MHz带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,@DsoIMPedanceOfALLSourceAPPLySetting@,3,0,0,9,0,0"
								></Command>
							<Command Description="通道调整偏执" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHANnel@Channel@:BIAS @SourceAmpVoltByV@"
								></Command>
							<Command Description="通道1 20MHz 带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHAN1:BWL 20MHz"
								></Command>
							<Command Description="通道2 20MHz 带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHAN2:BWL 20MHz"
								></Command>
							<Command Description="通道3 20MHz 带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHAN3:BWL 20MHz"
								></Command>
							<Command Description="通道4 20MHz 带宽限制" 
								InstrumentationName="GHz_MSO7000X"
								CommandType="scpi"
								SCPICmd=":CHAN4:BWL 20MHz"
								></Command>
						</Group>
						<Command Description="源直流输出" 
							InstrumentationName="信号源9500B"
							CommandType="scpi"
							SCPICmd="VOLTage @SourceAmpVoltByV@"
							></Command>
						<Command Description="源输出打开" 
							InstrumentationName="信号源9500B"
							CommandType="scpi"
							SCPICmd="OUTPut ON"
							></Command>
						<Command Description="通道@Channel@、@inputLevelBymV@mV档、@SourceIMPedanceName@:偏执校准" 
							InstrumentationName="GHz_MSO7000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_CaliOffset @Channel@,@BatchTaskIMPedanceSetting@,@inputLevelBymV@,@SourceAmpVoltByV@,40"	
							ProgramFuncOverSec="40"		
							></Command>	
						<Command Description="通道恢复偏执" 
							InstrumentationName="GHz_MSO7000X"
							CommandType="scpi"
							SCPICmd=":CHANnel@Channel@:BIAS 0"
							></Command>
					</ForeachLoop>			
		  		</ForeachLoop>
				<Command Description="源电压置为0" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="VOLTage 0"
					></Command>
				<Command Description="源输出关闭" 
					InstrumentationName="信号源9500B"
					CommandType="scpi"
					SCPICmd="OUTPut OFF"
					></Command>
		  	</ForeachLoop>
			<Command Description="源复位" 
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="*RST"
			></Command>
			<Command Description="保存校准数据" 
						InstrumentationName="GHz_MSO7000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannel"
			></Command>
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>