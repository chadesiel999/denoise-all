<?xml version="1.0" encoding="UTF-8"?>
<!--=======region 重要说明=====
[1]DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JiHe_MSO7000X，JiHe_MSO8000X), UU_USB374(示波表);
[2]CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器;
[3]AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位);
[4]QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时;
[5]基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令;
[6]一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容;
[7]如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空;
[8]对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准;
[9]此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec(程序函数超时时间，秒);
-->
<!--=======BatchTaskPart_CaliChannelGain 参数说明===== 
第1个参数: 表示要校准的通道，编号从1开始，可多个通道以'|'分隔；
第2个参数: 表示高阻还是低阻，LOW表示低阻，HIGH表示高阻；
第3个参数: 表示垂直档位，以mV为单位，浮点数
第4个参数: 表示输入信号的幅度值，以V为单位，浮点数
第5个参数: 表示包含的校准阶段，包括 ：Dsa_Adc_Fpga , Dsa_Adc , Fpga等
第6个参数: 表示校准值生效时间，用ms表示
第7个参数: 统计次数
第8个参数: 表示总体误差判据百分比，浮点数
第9个参数: 表示DSA每个控制字幅度改变百分比，浮点数
第10个参数: 表示ADC每个控制字幅度改变百分比，浮点数
第11个参数: 表示数字调节档位
第12个参数: 表示DSA控制字的最小值
第13个参数: 表示DSA控制字的最大值
第14个参数: 表示ADC控制字最小值
第15个参数: 表示ADC控制字最大值
第16个参数: 表示FPGA细调的最小值
第17个参数: 表示FPGA细调的最大值
第18个参数: 表示幅度值的获取方式,AMPL / STDD / CACL
-->
<InstrumentationAutoControlSolution SolutionDescription="JiHe_MSO7000X程控幅度校准方案." version="1.0.9.2">
  <Instrumentations Description="使用的仪器">
    <Instrumentation Name="Fluck9500b" Description="Fluck9500b" DriverType="VISA" Address="GPIB4::19::INSTR" Timeout="0" />
    <Instrumentation Name="JiHe_MSO7000X" Description="示波器" DriverType="VISA" IsOurTargetDso="true" Timeout="0" />
  </Instrumentations>
  <Tasks Description="任务列表">
    <Task Description="校准通道高阻、低阻全档位增益." ImportanceTipMessage="该任务是通过程控来校准示波器的通道增益。">
      <ForeachLoop Description="通道循环:" StartIndex="0" Count="4">
        <VarintDefine name="Channels" valuelist="1,2,3,4" />
        <Command Description="现在即将对“通道@Channels@” 进行校准，请确保将信号源的输出接入到通道！" CommandType="check" />
        <Group Description="示波器及信号源初始化">
          <Command Description="时基档0.0002s" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":TIM:SCAL 0.0002" AfterWaitSec="0" />
          <Command Description="采集模式为：HIGHres" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":ACQ:TYP HIGHres" AfterWaitSec="0" />
          <Command Description="触发模式为：EDGe" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":TRIG:TYP EDGe" AfterWaitSec="0" />
          <Command Description="触发源设置为：CH@Channels@" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":TRIG:EDG:SOUR C@Channels@" AfterWaitSec="0" />
          <Command Description="触发电平设置为：0" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":TRIG:EDG:LEV 0" AfterWaitSec="0" />
          <Command Description="源复位" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="*RST" AfterWaitSec="0" />
          <Command Description="源输出1打开" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="ROUTe:SIGNal CH1" AfterWaitSec="1" />
          <Command Description="源输出方波" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="SCOpe SQU" AfterWaitSec="0" />
          <Command Description="源输出1000Hz" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="FREQuency 1000" AfterWaitSec="0" />
          <Command Description="方波设置(SYMM)" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd=":PAR:SQU:POL SYMM" AfterWaitSec="1" />
        </Group>
        <ForeachLoop Description="阻抗循环: 低阻-》高阻" StartIndex="0" Count="2">
          <VarintDefine name="SourceIMPedanceName" valuelist="50欧姆,高阻" />
          <VarintDefine name="Rigol_SourceIMPedanceSetting" valuelist="50,INFinity" />
          <VarintDefine name="Fluck_SourceIMPedanceSetting" valuelist="50,1E6" />
          <VarintDefine name="BatchTaskIMPedanceSetting" valuelist="LOW,HIGH" />
          <VarintDefine name="IMPedanceOfALLSourceAPPLySetting" valuelist="2,0" />
          <VarintDefine name="ChnlYScaleStart" valuelist="2,2" />
          <VarintDefine name="ChnlYScaleCount" valuelist="9,12" />
          <Command Description="源OUTPut1:@SourceIMPedanceName@" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="ROUT:SIGN:IMP @Fluck_SourceIMPedanceSetting@" AfterWaitSec="1" />
          <ForeachLoop Description="垂直档位循环:" StartIndex="@ChnlYScaleStart@" Count="@ChnlYScaleCount@">
            <VarintDefine name="SourceAmpVoltByV" valuelist="0.003,0.006,0.012,0.03,0.06,0.12,0.3,0.6,1.2,3,6,12,20,20" />
            <VarintDefine name="InputLevelBymV" valuelist="0.5, 1 , 2 , 5 , 10, 20, 50, 100 , 200, 500, 1000, 2000, 5000, 10000" />
            <VarintDefine name="GainStage" valuelist="Fpga, Dsa_Adc_Fpga ,Dsa_Adc_Fpga,Dsa_Adc_Fpga ,Dsa_Adc_Fpga  ,Dsa_Adc_Fpga,Dsa_Adc_Fpga ,Dsa_Adc_Fpga  ,Dsa_Adc_Fpga   ,Dsa_Adc_Fpga,Dsa_Adc_Fpga ,Dsa_Adc_Fpga  ,Dsa_Adc_Fpga,Dsa_Adc_Fpga" />
            <Group Description="基线校准常量设置">
              <ConstVariantDefine name="DACCtrlWord" value="0, 50000" />
              <ConstVariantDefine name="GainErrorByLsb" value="20" />
              <ConstVariantDefine name="StaticTimes" value="2" />
              <ConstVariantDefine name="HardwareValidMs" value="400" />
              <ConstVariantDefine name="GainMaxWaitMilliseconds" value="25" />
            </Group>
            <Group Description="幅度校准常量设置">
              <ConstVariantDefine name="GainHardwareValidMs" value="200" />
              <ConstVariantDefine name="StaticTimes" value="2" />
              <ConstVariantDefine name="ErrorByPercent" value="0.5" />
              <ConstVariantDefine name="DSAStepPercent" value="12.2" />
              <ConstVariantDefine name="ADCStepPercent" value="0.06" />
              <ConstVariantDefine name="FPGAYLevelID" value="1" />
              <ConstVariantDefine name="DSACtrlWord" value="0, 32" />
              <ConstVariantDefine name="ADCCtrlWord" value="0, 255" />
              <ConstVariantDefine name="FpgaCtrlWord" value="500, 2000" />
              <ConstVariantDefine name="AmpMeasureType" value="STDD" />
            </Group>
            <Group Description="示波器通道设置">
              <Command Description="所有通道,@InputLevelBymV@mV档,@SourceIMPedanceName@,20MHz带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":FACTory:ALLSource:APPLy 1,@InputLevelBymV@,0,@IMPedanceOfALLSourceAPPLySetting@,3,0,0,9,0,0" AfterWaitSec="2" />
              <Command Description="通道1 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN1:BWL 20MHz" AfterWaitSec="0" />
              <Command Description="通道2 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN2:BWL 20MHz" AfterWaitSec="0" />
              <Command Description="通道3 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN3:BWL 20MHz" AfterWaitSec="0" />
              <Command Description="通道4 20MHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN4:BWL 20MHz" AfterWaitSec="1" />
            </Group>
            <Group Description="先校准基线0Div">
              <Command Description="源输出1关闭" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut OFF" AfterWaitSec="1" />
              <Command Description="@SourceIMPedanceName@基线0Div校准、@InputLevelBymV@mV档" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_CaliChannelBaseLine @Channels@,@BatchTaskIMPedanceSetting@,@InputLevelBymV@,0,@DACCtrlWord@,100,@GainErrorByLsb@,@StaticTimes@,@HardwareValidMs@,@GainMaxWaitMilliseconds@,true" ProgramFuncOverSec="25" />
              <Command Description="源输出1打开" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut ON" AfterWaitSec="1" />
            </Group>
            <Group Description="再校准幅度">
              <Command Description="源输出:@SourceAmpVoltByV@V" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="VOLTage @SourceAmpVoltByV@" AfterWaitSec="1" />
              <Command Description="通道@Channels@_@InputLevelBymV@mV档_@SourceIMPedanceName@:幅度校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_CaliChannelGain @Channels@,@BatchTaskIMPedanceSetting@,@InputLevelBymV@,@SourceAmpVoltByV@,@GainStage@,@GainHardwareValidMs@,@StaticTimes@,@ErrorByPercent@,@DSAStepPercent@,@ADCStepPercent@,@FPGAYLevelID@,@DSACtrlWord@,@ADCCtrlWord@,@FpgaCtrlWord@,@AmpMeasureType@" ProgramFuncOverSec="40" />
              <Command Description="源输出1关闭" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut OFF" AfterWaitSec="1" />
            </Group>
          </ForeachLoop>
        </ForeachLoop>
        <Command Description="源复位" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="*RST" AfterWaitSec="0" />
        <Command Description="保存校准时的温度" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_SetAnalogChannelTemperatue Gain" ProgramFuncOverSec="0" />
        <Command Description="保存校准数据" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannel" ProgramFuncOverSec="0" />
      </ForeachLoop>
    </Task>
  </Tasks>
</InstrumentationAutoControlSolution>