<?xml version="1.0" encoding="UTF-8"?>
<!--=======region 重要说明=====
[1]DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JiHe_MSO7000X，JiHe_MSO8000X), UU_USB374(示波表);
[2]CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器;
[3]AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位);
[4]QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时;
[5]基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令;
[6]一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容;
[7]如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空;
[8]对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准;
[9]此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec(程序函数超时时间，秒);
-->
<!--=======BatchTaskPart_TiAdc_JiHe_MSO7000X 参数说明===== 
第1个参数：通道组合构造成的交织方式，请使用Driver端代码中的AnalogAcquireModel.cs 之 AcqModeInterleaveDefines 之InterleaveName
第2个参数，需要校准的通道，Ch1、Ch2、Ch3、Ch4，可以用|连接两个同时校准的通道，如Ch1|Ch2
第3个参数，阻抗，low=50欧姆，低阻，higf表示高阻
第4个参数，以mV为单位的档位值，浮点数
第5个参数，输入信号频率，用MHz为单位，浮点数
第6个参数，单路信号的采样率，Msps为单位，浮点数
第7个参数，Gain误差门限，以百分之为单位，浮点数
第8个参数，Offset误差门限，以百分之为单位，浮点数
第9个参数，Phase误差门限，以飞秒(fs)单位，整数
第10个参数，调整步进(1~50)，整数
-->
<InstrumentationAutoControlSolution SolutionDescription="JiHe_MSO7000X程控TiAdc校准方案." version="1.0.9.2">
  <Instrumentations Description="使用的仪器">
    <Instrumentation Name="Fluck9500b" Description="Fluck9500b" DriverType="VISA" Address="GPIB4::19::INSTR" Timeout="0" />
    <Instrumentation Name="JiHe_MSO7000X" Description="示波器" DriverType="VISA" IsOurTargetDso="true" Timeout="0" />
  </Instrumentations>
  <Tasks Description="任务列表">
    <Task Description="校准各交织方式下各通道TiAdc." ImportanceTipMessage="该任务是通过程控来校准示波器的各交织方式下各通道TiAdc.">
      <ForeachLoop Description="通道循环:" StartIndex="0" Count="4">
        <VarintDefine name="Channels" valuelist="1,2,3,4" />
        <VarintDefine name="ModesStart" valuelist="0,2,4,6" />
        <Command Description="现在即将对“通道@Channels@” 进行校准，请确保将信号源的输出接入到通道！" CommandType="check" />
        <ForeachLoop Description="模式循环:" StartIndex="@ModesStart@" Count="2">
          <VarintDefine name="ModeName" valuelist="C1C2_5G, C1_10G, C1C2_5G, C2_10G, C3C4_5G, C3_10G, C3C4_5G, C4_10G" />
          <Group Description="示波器及信号源初始化">
            <Command Description="时基档0.000001s" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":TIM:SCAL 0.000001" AfterWaitSec="0" />
            <Command Description="采集模式为：NORMal" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":ACQ:TYP NORMal" AfterWaitSec="0" />
            <Command Description="源复位" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="*RST" AfterWaitSec="0" />
            <Command Description="源设置输出" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="ROUTe:SIGNal CH1" AfterWaitSec="0" />
            <Command Description="源正弦" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="SCOpe SIN" AfterWaitSec="0" />
            <Command Description="源频率1E9Hz" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="FREQuency 1E9" AfterWaitSec="0" />
            <Command Description="源阻抗50欧姆" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="ROUT:SIGN:IMP 50" AfterWaitSec="0" />
            <Command Description="源电压0.25V" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="VOLTage 0.25" AfterWaitSec="0" />
          </Group>
          <Group Description="基线校准常量设置">
            <ConstVariantDefine name="DACCtrlWord" value="0, 50000" />
            <ConstVariantDefine name="TiAdcErrorByLsb" value="20" />
            <ConstVariantDefine name="StaticTimes" value="2" />
            <ConstVariantDefine name="HardwareValidMs" value="400" />
            <ConstVariantDefine name="TiAdcMaxWaitMilliseconds" value="25" />
          </Group>
          <Group Description="幅度校准常量设置">
            <ConstVariantDefine name="GainHardwareValidMs" value="200" />
            <ConstVariantDefine name="StaticTimes" value="2" />
            <ConstVariantDefine name="TiAdcErrorByPercent" value="20" />
            <ConstVariantDefine name="DSAStepPercent" value="12.2" />
            <ConstVariantDefine name="ADCStepPercent" value="0.06" />
            <ConstVariantDefine name="FPGAYLevelID" value="1" />
            <ConstVariantDefine name="DSACtrlWord" value="0, 32" />
            <ConstVariantDefine name="ADCCtrlWord" value="0, 255" />
            <ConstVariantDefine name="FpgaCtrlWord" value="500, 2000" />
            <ConstVariantDefine name="TiAdcGainAmpMeasureType" value="AMPL" />
            <ConstVariantDefine name="TiAdcMaxWaitMilliseconds" value="25" />
          </Group>
          <Group Description="TiAdc校准常量设置">
            <ConstVariantDefine name="SourceFrequencyByMHz" value="1000" />
            <ConstVariantDefine name="GainErrorByPercent" value="0.15" />
            <ConstVariantDefine name="OffsetErrorByLSB" value="0.3" />
            <ConstVariantDefine name="PhaseErrorByPs" value="600" />
            <ConstVariantDefine name="AdjustStep" value="5" />
          </Group>
          <Group Description="示波器校准基线和幅度">
            <Command Description="所有通道,50mV档,低阻" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":FACTory:ALLSource:APPLy 1,50,0,2,1,0,0,9,0,0" AfterWaitSec="2" />
            <Command Description="存储深度：25K" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":FACT:STOR Of25KDots" AfterWaitSec="0" />
            <Command Description="通道1 1GHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN1:BWL 1GHz" AfterWaitSec="0" />
            <Command Description="通道2 1GHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN2:BWL 1GHz" AfterWaitSec="0" />
            <Command Description="通道3 1GHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN3:BWL 1GHz" AfterWaitSec="0" />
            <Command Description="通道4 1GHz 带宽限制" InstrumentationName="JiHe_MSO7000X" CommandType="scpi" SCPICmd=":CHAN4:BWL 1GHz" AfterWaitSec="1" />
            <Command Description="源输出关闭" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut OFF" AfterWaitSec="0" />
            <Command Description="通道@Channels@，低阻档，50mv档:基线0Div校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_CaliChannelBaseLine @Channels@,Low,50,0,@DACCtrlWord@,100,@TiAdcErrorByLsb@,@StaticTimes@,@HardwareValidMs@,@TiAdcMaxWaitMilliseconds@,true" ProgramFuncOverSec="25" />
            <Command Description="源输出打开" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut ON" AfterWaitSec="0" />
            <Command Description="通道(@Channels@)，低阻档，50mv档:幅度校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_CaliChannelGain @Channels@,Low,50,0.25,Dsa_Adc_Fpga,@GainHardwareValidMs@,@StaticTimes@, @TiAdcErrorByPercent@,@DSAStepPercent@,@ADCStepPercent@,@FPGAYLevelID@,@DSACtrlWord@,@ADCCtrlWord@,@FpgaCtrlWord@,@TiAdcGainAmpMeasureType@" ProgramFuncOverSec="25" />
          </Group>
          <Command Description="模式(@ModeName@),通道(@Channels@):Tiadc校准" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_TiAdc_JiHe_MSO7000X @ModeName@,@Channels@,Low,50,@SourceFrequencyByMHz@,2500,@GainErrorByPercent@,@OffsetErrorByLSB@,@PhaseErrorByPs@,@AdjustStep@" ProgramFuncOverSec="40" />
          <Command Description="源输出关闭" InstrumentationName="Fluck9500b" CommandType="scpi" SCPICmd="OUTPut OFF" AfterWaitSec="0" />
        </ForeachLoop>
        <Command Description="保存校准数据" InstrumentationName="JiHe_MSO7000X" IsProgramFunc="true" ProgramFuncName="BatchTaskPart_SaveCaliDataToFile TiAdc_PhaseOffsetGain_JiHe_MSO7000X" ProgramFuncOverSec="0" />
      </ForeachLoop>
    </Task>
  </Tasks>
</InstrumentationAutoControlSolution>