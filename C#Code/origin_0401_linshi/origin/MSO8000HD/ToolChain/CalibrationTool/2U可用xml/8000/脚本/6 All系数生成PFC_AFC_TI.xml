<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->
<!--=======endregion 重要说明=====-->

<!--
	参数定义
	1：channel list
	2: 阻抗 HIGH LOW
	3：幅度挡 inputLevelBymV
	4：输入信号（单位mV）SourceAmpVoltBymV
	5：校准时限(单位S)
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO8000X程控校准方案" version="1.0.0.0" creator="pengbo" LastModifier="pengbo">
  <Instrumentations Description="endregion 方案中使用到的仪器的定义">
    <!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
    <Instrumentation
				Name="GHz_MSO8000X"
				Description="GHz_MSO8000X示波器"
				DriverType="VISA"
				Address="TCPIP0::DESKTOP-1853::inst0::INSTR"
				IsOurTargetDso="true"
				Timeout="0"
			></Instrumentation>
  </Instrumentations>

  <!--=======region 方案中任务列表=====-->
  <Tasks>
	<Task Description="PFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的上升时间和相位。">
		<ForeachLoop StartIndex="1" Count="1">
			<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="All-20G,All-20G,All-20G,All-20G"></VarintDefine>
			<!--==广谱信号的基频频率-->
			<ConstVariantDefine name="InputSignalFreqByHz"  value="50e6"></ConstVariantDefine>
			<!--==输入广谱信号的谐波频率间隔-->
			<ConstVariantDefine name="InputSignalHarmonicGapByHz"  value="50e6"></ConstVariantDefine>
			<ConstVariantDefine name="DUTSamplingRateBySps"  value="40e9"></ConstVariantDefine>
			<!--==系统采样率,单位Hz-->
			<!-- <ConstVariantDefine name="SamplingRateBySps"  value="40e9"></ConstVariantDefine> -->
			<!--==系统带宽-->
			<ConstVariantDefine name="TagetBandwidthByhz"  value="8e9"></ConstVariantDefine>
			<!--==FFT估计的长度-->
			<!-- <ConstVariantDefine name="FFTEstimationNum"  value="80e3"></ConstVariantDefine> -->
			<!--==参考波形-->
			<!-- <ConstVariantDefine name="RefwaveFileName"  value=".\Resources\Keysight_ref_data_20GSPS_8GHz.mat"></ConstVariantDefine> -->
			<ConstVariantDefine name="RefwaveFileName"  value="C:\Users\Admin\Desktop\CYW0507\MSO8000HD\ScopeX.Hardware.Calibration.Tool\bin\Debug\net6.0-windows\MSO8000HD\NULL\PFCDataFiles\std\250514_055205_Ch1.csv"></ConstVariantDefine>
			<!--==系数量化位宽-->
			<ConstVariantDefine name="CoeQuantiBit"  value="12"></ConstVariantDefine>
			<!--==Debug输出开关-->
			<ConstVariantDefine name="CoeLength"  value="2048"></ConstVariantDefine>
			<ConstVariantDefine name="REFSamplingRateBySps" value="100e9"></ConstVariantDefine>
			
			<!--==频域补偿的长度-->
			<!-- <ConstVariantDefine name="FFTCompLen"  value="2048"></ConstVariantDefine> -->
			<!-- <ConstVariantDefine name="AveFocusFreq"  value="1e9"></ConstVariantDefine> -->
			<!--==相位拟合精度-->
			<ConstVariantDefine name="SmoothingParam_Phase"  value="0.9999"></ConstVariantDefine>
			<!--==不参与拟合的频点文件名称-->
			<!-- <VarintDefine name="UnconcernedFreqFileName"  valuelist=".\Resources\UnconcernedFreqFileNameC3.txt,.\Resources\UnconcernedFreqFileNameC3.txt"></VarintDefine> -->
				<VarintDefine name="UnconcernedFreqFileName"  valuelist="[]"></VarintDefine>
			<!--==FIR系数的保留精度-->
			<!-- <ConstVariantDefine name="Threshold"  value="0.5e-2"></ConstVariantDefine> -->
			<!--==补偿后快沿观测窗口-->
			<!-- <ConstVariantDefine name="VisualTimeRangeFileName"  value="-"></ConstVariantDefine> -->
			<!--==观测补偿信号后的插值倍率-->
			<ConstVariantDefine name="InterpRate"  value="100"></ConstVariantDefine>
			<ConstVariantDefine name="FileRdType" value=".txt"></ConstVariantDefine>
			<!--==绘图标致-->
			<ConstVariantDefine name="FigureIllustrationSw"  value="off"></ConstVariantDefine>
			<!--==绘图标致 -->
			<ConstVariantDefine name="Filtertype" value="F"></ConstVariantDefine>
			<!--==绘图标致 -->
			<ConstVariantDefine name="RefwaveFileColumnNum" value="5"></ConstVariantDefine>

			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="3,3"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="7,3"></VarintDefine>
				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="inputLevelBymV"   valuelist="1,2,5,10,20,50,100,200,500,1000"></VarintDefine>
					<!-- 避免重复采集数据，使用其他挡位的数据 -->
					<VarintDefine name="UseWhichScaleData"   valuelist="20,20,20,20,20,50,100,200,200,200"></VarintDefine>	
					<Command Description="生成校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_Pfc.dll,
						CoefficientType=PFC,
						Channel=CH@OpenChannel@,
						SaveCoefficientFileName=FreqDomainPFCCoe_FPGA_@CoeQuantiBit@bit.txt,
						SourceFiles_Path=PFCDataFiles,
						SourceFilesFilterPrefixName=WaveData_C@OpenChannel@_@UseWhichScaleData@_,
						DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						DebugSaveFilePrefixName=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						@InterleaveName@,
						OtherParameter=InputSignalFreqByHz=@InputSignalFreqByHz@ InputSignalHarmonicGapByHz=@InputSignalHarmonicGapByHz@ DUTSamplingRateBySps=@DUTSamplingRateBySps@ TagetBandwidthByhz=@TagetBandwidthByhz@ RefwaveFileName=@RefwaveFileName@ CoeQuantiBit=@CoeQuantiBit@ CoeLength=@CoeLength@ REFSamplingRateBySps=@REFSamplingRateBySps@ SmoothingParam_Phase=@SmoothingParam_Phase@ InterpRate=@InterpRate@ FileRdType=@FileRdType@ FigureIllustrationSw=@FigureIllustrationSw@ Filtertype=@Filtertype@ RefwaveFileColumnNum=@RefwaveFileColumnNum@">
					</Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送PFC校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=PFC,
						CoeQuantiBit=0,
						CoefficientKey=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=FreqDomainPFCCoe.txt,
						MagCompOrder=0"
				    ></Command>		
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送PFC校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams
						CoefficientType=PFC,
						CoeQuantiBit=@CoeQuantiBit@,
						CoefficientKey=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=FreqDomainPFCCoe_FPGA_@CoeQuantiBit@Bit.txt,
						MagCompOrder=0"
				    ></Command>	
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>
	</Task>  
	<Task Description="IFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的TiAdc和AFC">
		<ForeachLoop StartIndex="0" Count="4">
			<VarintDefine name="OpenChannel"  		valuelist="1,2,3,4"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="All-20G,All-20G,All-20G,All-20G"></VarintDefine>
				
			<!--==FPGA中的系数量化位宽-->
			<ConstVariantDefine name="QuantiBitFPGA"  value="12"></ConstVariantDefine>
			<!--==合并的模式-->
			<ConstVariantDefine name="MergingMode"  value="TI_AFC_PFC"></ConstVariantDefine>
			<!--==生成滤波器的种类-->
			<ConstVariantDefine name="FilterType"  value="F"></ConstVariantDefine>
			<!--==频域滤波器的结构是串行还是并行-->
			<ConstVariantDefine name="ParallelFreqFilter"  value="Y"></ConstVariantDefine>
			<!--==生成的系数长度-->
			<ConstVariantDefine name="FilterCoeLength"  value="2048"></ConstVariantDefine>
			<!--==TI的通道数-->
			<ConstVariantDefine name="TIChannelNumber"  value="2"></ConstVariantDefine>
			<!--==Debug输出开关-->
			<ConstVariantDefine name="OutputDebugFile"  value="N"></ConstVariantDefine>
			<!--==TI系数的输入类型-->
			<ConstVariantDefine name="TICoeType" value="F"></ConstVariantDefine>
			<!--==AFC系数的输入类型-->
			<ConstVariantDefine name="AFCCoeType" value="T"></ConstVariantDefine>
			<!--==PFC系数的输入类型 -->
			<ConstVariantDefine name="PFCCoeType" value="F"></ConstVariantDefine>		
			<!--==绘图标致 -->
			<ConstVariantDefine name="FigureIllustrationSw" value="OFF"></ConstVariantDefine>
			
			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="3,3"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="7,3"></VarintDefine>

				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<!-- <VarintDefine name="SourceAmpVoltByMv" valuelist="1,2,5,10,20,50,100,200,500,1000"></VarintDefine> -->
					<VarintDefine name="inputLevelBymV"   valuelist="1,2,5,10,20,50,100,200,500,1000"></VarintDefine>					
					<Command Description="通道@OpenChannel@，阻抗@BatchTaskIMPedanceSetting@，档位@inputLevelBymV@，生成IFC校准数据"
						InstrumentationName="GHz_MSO8000HD"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_CoeMergByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_CoeMerging.dll,
						CoefficientType=@MergingMode@,
						TIADCCoe=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@\TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_TiadcCoeFreqDomain.txt,
						AFCCoe=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@\AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv_TimeDomainAFCCoe.txt,
						PFCCoe=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@\PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_FreqDomainPFCCoe.txt,
						OtherParameter=QuantiBitFPGA=@QuantiBitFPGA@ MergingMode=@MergingMode@ FilterType=@FilterType@ ParallelFreqFilter=@ParallelFreqFilter@ FilterCoeLength=@FilterCoeLength@ OutputDebugFile=@OutputDebugFile@ DebugFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@ DebugFilePrefix=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv TIChannelNumber=@TIChannelNumber@ TICoeType=@TICoeType@ AFCCoeType=@AFCCoeType@ PFCCoeType=@PFCCoeType@"
				    ></Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送IFC校准数据"
						InstrumentationName="GHz_MSO8000HD"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams
						CoefficientType=IFC,
						CoeQuantiBit=0,
						CoefficientKey=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=@MergingMode@_FreqDomain_@QuantiBitFPGA@Bit.txt,
						MagCompOrder=0,"
				    ></Command>	
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>
		<!--<Command Description="保存校准数据" 
				InstrumentationName="GHz_MSO8000HD"
				IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SaveCaliDataToFile CoefficientsParams"
		></Command>-->	
    </Task>
  </Tasks>
</InstrumentationAutoControlSolution>
