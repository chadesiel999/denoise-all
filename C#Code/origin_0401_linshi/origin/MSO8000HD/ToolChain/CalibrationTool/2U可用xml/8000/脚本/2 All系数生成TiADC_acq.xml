<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO7000X), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->
<!--=======endregion 重要说明=====-->

<!--
	参数定义
	1：channel list
	2: 阻抗 HIGH LOW
	3：幅度挡 inputLevelBymV
	4：输入信号（单位mV）SourceAmpVoltBymV
	5：校准时限(单位S)
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO8000X程控校准方案" version="1.0.0.0" creator="pengbo" LastModifier="pengbo">
  <Instrumentations Description="endregion 方案中使用到的仪器的定义">
    <!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
    <Instrumentation
				Name="GHz_MSO8000HD"
				Description="GHz_MSO8000HD示波器"
				DriverType="VISA"
				Address="TCPIP0::DESKTOP-1853::inst0::INSTR"
				IsOurTargetDso="true"
				Timeout="0"
			></Instrumentation>
  </Instrumentations>

  <!--=======region 方案中任务列表=====-->
  <Tasks>
	<Task Description="TiADC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的ADC平坦度校准。">
		<ForeachLoop StartIndex="0" Count="1">
			<VarintDefine name="OpenChannel"  		valuelist="1 ,2,3,4"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="All-20G,All-20G,All-20G,All-20G"></VarintDefine>
			<!--==TIADC的路数-->
		
			<!--==系统采样率,单位Hz-->
			<ConstVariantDefine name="SamplingRate"  value="40e9"></ConstVariantDefine>
			<!--==补偿滤波器的长度-->
			<ConstVariantDefine name="CoeLength"  value="2048"></ConstVariantDefine>
			<!--==FPGA中系数的量化精度-->
			<ConstVariantDefine name="CoeQuantiWidth"  value="12"></ConstVariantDefine>
			<!--==TIADC的校准级联个数-->
			<ConstVariantDefine name="CascadeOrder"  value="5"></ConstVariantDefine>
			<!--==FFT误差估计方法的信号长度-->
			<ConstVariantDefine name="FFTLen"  value="10000"></ConstVariantDefine>
			<!--==是否进行误差拟合的选项-->
			<ConstVariantDefine name="FitOption"  value="-"></ConstVariantDefine>			
			<!--==相位拟合精度-->
			<ConstVariantDefine name="FitSmoothingParamPhase"  value="-"></ConstVariantDefine>
			<!--==幅度拟合精度-->
			<ConstVariantDefine name="FitSmoothingParamMag"  value="-"></ConstVariantDefine>	<!--==第一个标识符-->
			<ConstVariantDefine name="Identifier_1st"  value="_"></ConstVariantDefine>
			<!--==第二个标识符-->
			<ConstVariantDefine name="Identifier_2nd"  value="M"></ConstVariantDefine>
			<!--==第一个标识符的索引-->
			<ConstVariantDefine name="Identifier_1st_index"  value="1"></ConstVariantDefine>
			<!--==第二个标识符的索引-->
			<ConstVariantDefine name="Identifier_2nd_index"  value="1"></ConstVariantDefine>
			<!--==绘图标致-->
			<ConstVariantDefine name="FigureIllustrationSw"  value="off"></ConstVariantDefine>
			<!--==输出系数种类-->
			<ConstVariantDefine name="CoeType"  value="F"></ConstVariantDefine>
			<!--==校正输出频谱的信号频率编号-->
			<ConstVariantDefine name="SpecialFreq"  value="38"></ConstVariantDefine>
			<!--==输出频域滤波系数时，是否为并行结构-->
			<ConstVariantDefine name="FreqCoeParallel"  value="N"></ConstVariantDefine>



			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="2,4"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="1,4"></VarintDefine>
				<!--==档位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="inputLevelBymV"   valuelist="10,20,50,100,200,500,1000"></VarintDefine>
					
					<!--==先采集板后处理板板子循环==-->
						<ForeachLoop StartIndex="0" Count="2">
							<VarintDefine name="TiPath"  valuelist="4,4,2"></VarintDefine>
							<VarintDefine name="DecimationMode"  valuelist="Y,Y,N"></VarintDefine>
							<VarintDefine name="DecimationRate"  valuelist="2,2,1"></VarintDefine>
							<VarintDefine name="DecimationBeginIndex"  valuelist="1,2,1"></VarintDefine>
							<VarintDefine name="BoardNameString"  valuelist="acq1,acq2,pro1"></VarintDefine>

							<Command Description="通道@OpenChannel@，阻抗@BatchTaskIMPedanceSetting@，档位@inputLevelBymV@，生成TiAdc校准数据"
								InstrumentationName="GHz_MSO8000HD"
								IsProgramFunc="true"
								ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_TIADC.dll,
								CoefficientType=TI,
								Channel=CH@OpenChannel@,
								SaveCoefficientFileName=TiadcCoeQuantied_@CoeQuantiWidth@bit.txt,
								SourceFiles_Path=AFCData\@BatchTaskIMPedanceSetting@\@InterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
								SourceFilesFilterPrefixName=Data_,
								DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
								DebugSaveFilePrefixName=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
								@InterleaveName@,
								OtherParameter=SamplingRate=@SamplingRate@ TiPath=@TiPath@ BoardNameString=@BoardNameString@ CoeLength=@CoeLength@ CoeQuantiWidth=@CoeQuantiWidth@ CascadeOrder=@CascadeOrder@ FFTLen=@FFTLen@ Identifier_1st=@Identifier_1st@ Identifier_2nd=@Identifier_2nd@ Identifier_1st_index=@Identifier_1st_index@ Identifier_2nd_index=@Identifier_2nd_index@ FigureIllustrationSw=@FigureIllustrationSw@ CoeType=@CoeType@ SpecialFreq=@SpecialFreq@ FreqCoeParallel=@FreqCoeParallel@ DecimationMode=@DecimationMode@ DecimationRate=@DecimationRate@ DecimationBeginIndex=@DecimationBeginIndex@">
							</Command>
							<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送TiAdc校准数据"
								InstrumentationName="GHz_MSO8000HD"
								IsProgramFunc="true"
								ProgramFuncName="BatchTaskPart_SendCoefficientParams 
								CoefficientType=TI,
								CoeQuantiBit=0,
								CoefficientKey=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
								SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
								SaveCoefficientPathAndFileName=TiadcCoeFreqDomain_@BoardNameString@.txt,
								MagCompOrder=0,"
						    ></Command>		
							<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送TiAdc校准数据"
								InstrumentationName="GHz_MSO8000HD"
								IsProgramFunc="true"
								ProgramFuncName="BatchTaskPart_SendCoefficientParams
								CoefficientType=TI,
								CoeQuantiBit=@CoeQuantiWidth@,
								CoefficientKey=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
								SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
								SaveCoefficientPathAndFileName=TiadcCoeQuantied_@CoeQuantiWidth@Bit_@BoardNameString@.txt,
								MagCompOrder=0,"
						    ></Command>	
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>

    </Task>
  </Tasks>
</InstrumentationAutoControlSolution>
