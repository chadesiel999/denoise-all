<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(OurDso), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="OurDso程控校准方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="信号源"
			Description="信号源"
			DriverType="VISA"
			Address="USB0::0x1AB1::0x0641::DG4C140300023::INSTR"
			Timeout="0"
			></Instrumentation>
			<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="OurDso"
			Description="10G示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="DBI-通道增益校准" ImportanceTipMessage="该任务是通过程控来校准示波器的通道增益。">
				
			<Command Description="时基档1ms" 
				InstrumentationName="OurDso"
				CommandType="scpi"
				SCPICmd=":TIM:SCAL 0.001"
			></Command>
			<Group Description="设置为ADCDebug模式,关闭相关数字处理功能">
				<Command Description="设置为ADCDebug模式,关闭相关数字处理功能。" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_AdcDataDebugMode:true,bEnable_DigitTrigger:true,bEnable_AcqbdInterpolation:true"
				></Command>			
				<Command Description="设置为ADCDebug模式,关闭相关数字处理功能" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_CorrectTiAdc:true,bEnable_AcqBd_Afc:false,bEnable_AcqBd_Pfc:false,bEnable_Dbi_IntDelay:true"
				></Command>			
				<Command Description="设置为ADCDebug模式,关闭相关数字处理功能" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_Dbi_AmpFreqCoef:false,bEnable_Dbi_AntiImageCoef:true,bEnable_Dbi_FractionaryDelayCoef:true"
				></Command>			
				<Command Description="设置为ADCDebug模式,关闭相关数字处理功能" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_Dbi_OverlapPhaseFreqDelayCoef:true,bEnable_Dbi_LocalOscillatorCoef:true,bEnable_Dbi_MultiRadioInterpolation:true"
				></Command>			
				<Command Description="设置为ADCDebug模式,关闭相关数字处理功能" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_Dbi_PhaseFreqCoef:false,bEnable_Dbi_IsSubbandMergeMode:true,bEnable_ProcBd_Average:false"
				></Command>			
			</Group>
			<Command Description="源OUTPut1:50欧姆" 
				InstrumentationName="信号源"
				CommandType="scpi"
				SCPICmd=":OUTPut1:IMPedance 50"
			></Command>			
			<Command Description="打开源输出，用于幅度检查" 
				InstrumentationName="信号源"
				CommandType="scpi"
				SCPICmd="OUTPut1:STATe ON"
			></Command>

			<ForeachLoop StartIndex="0" Count="1" Description="四个通道依次校准">
				<VarintDefine name="Curr_Channel" valuelist="1,2,3,4"></VarintDefine>
				<VarintDefine name="Curr_DebugChannel" valuelist="0,1,2,3"></VarintDefine>

				<Command Description="检查信号源与示波器的连接情况,目前需要接入到通道→@Curr_Channel@" 
				InstrumentationName="信号源"
				CommandType="check"
				SCPICmd=""
				></Command>
				
				<Command Description="设置iDbi_DebugChannelID：@Curr_DebugChannel@" 
					InstrumentationName="OurDso"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,iDbi_DebugChannelID:@Curr_DebugChannel@"
				></Command>				
						
				<ForeachLoop StartIndex="2" Count="4" Description="每个幅度档位">		
					<VarintDefine name="YScaleBymV" valuelist="1,2,5,10,20,50,100,200,500,1000"></VarintDefine>							
					<VarintDefine name="YScaleByV"  valuelist="0.001,0.002,0.005,0.01,0.02,0.05,0.1,0.2,0.5,1"></VarintDefine>							
					<VarintDefine name="TargetAmpBymV" valuelist="6,12,30,60,120,300,600,1200,3000,6000"></VarintDefine>							
					<VarintDefine name="AWGOutputAmp" valuelist="0.006,0.012,0.03,0.06,0.12,0.3,0.6,1.2,3.0,6.0"></VarintDefine>							
					<Command Description="源输出:1K,@AWGOutputAmp@V" 
						InstrumentationName="信号源"
						CommandType="scpi"
						SCPICmd=":SOURce1:APPLy:SQUare 1000,@AWGOutputAmp@,0.0,0"
					></Command>
					
					<Command Description="通道幅度档控制,当前CH@Curr_Channel@,幅度档@YScaleBymV@mV" 
						InstrumentationName="OurDso"
						CommandType="scpi"
						SCPICmd=":CHAN@Curr_Channel@:SCAL @YScaleByV@"
					></Command>
						
					<Command Description="设置通道CH@Curr_Channel@:幅度档=@YScaleBymV@mV" 
						InstrumentationName="OurDso"
						CommandType="scpi"
						SCPICmd=":FACT:ALLS:APPL 1,@YScaleBymV@,0,2,1,0,0,0,0"
						ProgramFuncOverSec="5"						
					></Command>
					
					<Command Description="通道@Curr_Channel@,档位@YScaleBymV@mV，子带1 ,幅度校准 " 
						InstrumentationName="OurDso"
						CommandType="scpi"
						SCPICmd=""
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_CaliDbiChannelGain @Curr_Channel@,1,low,@YScaleBymV@,@TargetAmpBymV@,Dsa,1500,0,1,1,1"
						ProgramFuncOverSec="60"
					></Command>
				</ForeachLoop>		
			</ForeachLoop>					
			
			<Command Description="保存校准数据，DBI模拟通道数据类型是7" 
				InstrumentationName="OurDso"
				CommandType="scpi"
				SCPICmd=":FACT:CDAT7:SAV"
			></Command>
												
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>