				></Command>
			    <ForeachLoop StartIndex="0" Count="10">
				   <VarintDefine name="CoumlnExcel"      valuelist="D,H,L,P,T,X,AB,AF,AJ,AN"></VarintDefine>
					<VarintDefine name="DsoYScale"  valuelist=" 1, 2, 5, 10, 20, 50,100,200, 500,1000"></VarintDefine>
			        <VarintDefine name="YValue"  valuelist="     6   ,  12,   30,   60, 120,  300,  600, 1200,  3000,3000"></VarintDefine>
			        <VarintDefine name="TrueYValue"  valuelist="2.121,4.243,10.61,21.21,42.43,106.1,212.1,424.3,1061,1061"></VarintDefine>   
						<Command Description="所有通道,低阻@DsoYScale@mV档" 
