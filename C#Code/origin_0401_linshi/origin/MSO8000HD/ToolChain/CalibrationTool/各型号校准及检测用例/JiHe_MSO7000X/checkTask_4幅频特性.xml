				CommandType="scpi"
				SCPICmd="LEV 2.12mV"
				></Command>	
			<Command Description="源输出打开" 
				InstrumentationName="射频信号源"
				CommandType="scpi"
				SCPICmd="OUTP ON"
				></Command>		
			<ForeachLoop StartIndex="0" Count="4">	
			<VarintDefine name="CoumlnExcelID" valuelist="1,2,3,4"></VarintDefine>				
				<Command Description="设置参数测量源" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEASure:ITEM@CoumlnExcelID@:SOURce CHAN@CoumlnExcelID@"
					></Command>
				<Command Description="设置参数测量项目" 
					InstrumentationName="JPO6000"
					CommandType="scpi"
					SCPICmd=":MEASure:ITEM@CoumlnExcelID@:TYPe AMPL"
					></Command>					
			</ForeachLoop>
			    <Command Description="现在即将对通道1进行4G幅频扫描，请确保将信号源的输出接入到BNC通道！" 
				InstrumentationName="射频信号源"
				CommandType="check"
				SCPICmd=""
				></Command>
			    <ForeachLoop StartIndex="6" Count="2">
				    <VarintDefine name="CoumlnExcel"      valuelist="B, F,J,N,R,V,Z,AD,AH,AL"></VarintDefine>
					<VarintDefine name="DsoYScale"  valuelist=" 1, 2, 5, 10, 20, 50,100,200, 500,1000"></VarintDefine>
			        <VarintDefine name="YValue"  valuelist="     6   ,  12,   30,   60, 120,  300,  600, 1200,  3000,5656"></VarintDefine>
			        <VarintDefine name="TrueYValue"  valuelist="2.121,4.243,10.61,21.21,42.43,106.1,212.1,424.3,1061,1061"></VarintDefine>   
					<Command Description="所有通道,低阻@DsoYScale@mV档" 
						 InstrumentationName="JPO6000"
						 CommandType="scpi"
						 SCPICmd=":FACTory:ALLSource:APPLy 1,@DsoYScale@,0,2,0,0,0,0,0,0"
						 ></Command>
					<Command Description="源输出1:@YValue@mV" 
						 InstrumentationName="射频信号源"
						 CommandType="scpi"
						 SCPICmd="LEV @TrueYValue@mV"
						  AfterWaitSec="3"
						 ></Command>		 
					<ForeachByFileLine Description="扫频，并保存幅度测量数据" FileID="扫频频点表" FileName=".\各型号校准及检测用例\4G通道_频点表.txt">
						<Command Description="信号源输出@FID扫频频点表:Column1@" 
								InstrumentationName="射频信号源"
								CommandType="scpi"
								SCPICmd=":FREQ @FID扫频频点表:Column1@"																
						></Command>		
						<Command Description="设置示波器时基档@FID扫频频点表:Column2@" 
								InstrumentationName="JPO6000"
								CommandType="scpi"
								SCPICmd=":TIM:SCAL @FID扫频频点表:Column2@"
								AfterWaitSec="0.5"								
						></Command>	
						<Command Description="Ch1幅度" 
					         InstrumentationName="JPO6000"
					         CommandType="scpi"
					         SCPICmd=":MEAS:ITEM1:VAL ?"
					         ReadBackResultWriteAtExcelCell="4G幅频特性!@CoumlnExcel@@FID扫频频点表:Column3@"
					         ></Command>
						</ForeachByFileLine>		
				</ForeachLoop>
				
