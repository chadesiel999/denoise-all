<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(GHz_MSO8000X_8G), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->
<!--
	参数定义
	//[0]其中1|2 表示通道，编号从1开始；
	//[1]表示高阻还是低阻，low=50欧姆，低阻，higf表示高阻。
	//[2]以mV为单位的档位值，浮点数
	//[3]0格或3格
	//[4]通道最小粗调值
	//[5]通道最大粗调值
	//[6]调节步进值
	//[7]总体误差判据，百分比表示 
	//[8]统计次数
	//[9]校准数据生效时间，用ms表示
	//[10]最大超时时间，用s表示
	//[11]:是否计算步进
	//[12]:Delta:3Div阈值,8G通道专用
-->
<InstrumentationAutoControlSolution SolutionDescription="GHz_MSO8000X_8G程控校准方案">

	<Instrumentations Description="使用的仪器">
		<Instrumentation Name="GHz_MSO8000X_8G" Description="GHz_MSO8000X_8G示波器" DriverType="VISA" IsOurTargetDso="true" Timeout="0" />
	</Instrumentations>
	
	<Tasks Description="任务列表">
		<Task Description="校准通道高阻、低阻全档位基线" ImportanceTipMessage="该任务是通过程控来校准示波器的通道基线。">

			<Group Description="示波器通道设置">
				<Command Description="时基档1ms" InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi" 
					SCPICmd=":TIM:SCAL 0.0002"/>
				<Command Description="打开高分辨率模式"  InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi"
					SCPICmd=":ACQuire:TYPe HIGHres" />
				<Command Description="现在即将对通道基线进行校准，请确保将无输入信号接入通道！" InstrumentationName="GHz_MSO8000X_8G" CommandType="check"
					SCPICmd="" />
			</Group>

			<!--校准10mv及以上,0div及3div-->
			<ForeachLoop Description="低阻" StartIndex="4" Count="7">
				<VarintDefine name="inputLevelBymV"  		valuelist="0.5 ,1   ,2   ,5   ,10  ,20  ,50  ,100 ,200 ,500 ,1000,2000 ,5000,10000"></VarintDefine>
				<VarintDefine name="Step"  					valuelist="50  ,50  ,50  ,50  ,100 ,100 ,100 ,100 ,100 ,100 ,100 ,100  ,100 ,100  "></VarintDefine>
				<VarintDefine name="TotalErrorByPercent"  	valuelist="40   ,40   ,20   ,10   ,7   ,7   ,5   ,5   ,5   ,5   ,5   ,5    ,5   ,5    "></VarintDefine>
				<VarintDefine name="PerformFlag"  			valuelist="false,false,false,false,true,false,false,false,false,false,false,false,false,false "></VarintDefine>

				<Group Description="示波器通道设置">
					<Command Description="所有通道,@inputLevelBymV@mV档,低阻,20MHz带宽限制" InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi" AfterWaitSec="1"
							SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,2,3,3,0,9,0,0" />
					<Command Description="通道1 20MHz 带宽限制" InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi"
						SCPICmd=":CHAN1:BWL 20MHz" />
					<Command Description="通道2 20MHz 带宽限制"  InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi"
						SCPICmd=":CHAN2:BWL 20MHz"/>
					<Command Description="通道3 20MHz 带宽限制" InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi" 
						SCPICmd=":CHAN3:BWL 20MHz"/>
					<Command Description="通道4 20MHz 带宽限制" InstrumentationName="GHz_MSO8000X_8G" CommandType="scpi"
						SCPICmd=":CHAN4:BWL 20MHz" 						
						AfterWaitSec="4" />

				</Group>
				<Command Description="@inputLevelBymV@mV档、低阻:基线0Div校准" InstrumentationName="GHz_MSO8000X_8G" IsProgramFunc="true" ProgramFuncOverSec="30"	
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,0,0,50000,@Step@,@TotalErrorByPercent@,3,600,40,true"/>	
				<Command Description="@inputLevelBymV@mV档、低阻:基线3Div校准" InstrumentationName="GHz_MSO8000X_8G" IsProgramFunc="true" ProgramFuncOverSec="30"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,3,0,20000,@Step@,@TotalErrorByPercent@,3,600,40,false"/>
				<Command Description="@inputLevelBymV@mV档、低阻:基线-3Div校准" InstrumentationName="GHz_MSO8000X_8G" IsProgramFunc="true" ProgramFuncOverSec="30"
					ProgramFuncName="BatchTaskPart_CaliChannelBaseLine 1|2|3|4,LOW,@inputLevelBymV@,-3,0,20000,@Step@,@TotalErrorByPercent@,3,600,40,false"/>
				<Command Description="拷贝校准数据:10mv->1,2,5mv" 
					InstrumentationName="GHz_MSO8000X_8G"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_AnalogCaliDataCopy 1|2|3|4,@inputLevelBymV@,1|2|5,LOW,BaseLine,@PerformFlag@"
				></Command>
			</ForeachLoop>
			
			<Command Description="保存校准时的温度" 
				InstrumentationName="GHz_MSO8000X_8G"
				IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SetAnalogChannelTemperatue Baseline"/>
				
			<Command Description="保存校准数据" InstrumentationName="GHz_MSO8000X_8G" IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SaveCaliDataToFile AnalogParams" />	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>