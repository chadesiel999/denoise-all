<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="TiADC程控校准方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO8000X"
			Description="GHz_MSO8000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准各交织方式下各通道TiAdc" ImportanceTipMessage="该任务是通过程控来校准示波器的各交织方式下各通道TiAdc。">
			<Group Description="信号源及示波器控制">
				<Command Description="设置时基到实时档（100ns/div）"
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 1E-7"
					AfterWaitSec="0"
				></Command>
				<Command Description="打开正常采集模式" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe NORMal"
				></Command>
				<Command Description="所有通道,100mV档,低阻" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":FACTory:ALLSource:APPLy 1,100,0,2,0,0,0,9,0,0"
					AfterWaitSec="0"
					></Command>
				<Command Description="通道1 1GHz 带宽限制" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":CHAN1:BWL FULL"
					></Command>
				<Command Description="通道2 1GHz 带宽限制" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":CHAN2:BWL FULL"
					></Command>
				<Command Description="通道3 1GHz 带宽限制" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":CHAN3:BWL FULL"
					></Command>
				<Command Description="通道4 1GHz 带宽限制" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":CHAN4:BWL FULL"
					></Command>
				<Command Description="目标示波器状态准备：系统配置:打开数字触发、打开DSP"
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:false,bEnable_AcqDigitTrigger:false,bEnable_Dsp:false,bEnable_CorrectTiAdc:false,bEnable_OpenCrystal:true"
				></Command>	
				
			</Group>

			<ForeachLoop StartIndex="0" Count="2">	
				<VarintDefine name="OpenChannel"  		valuelist="1,3"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G,C1C3-20G"></VarintDefine>
				<Command Description="切到正确的交织模式" 
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":FACT:CHAN:ACT @InterleaveName@"
					AfterWaitSec="2"
					></Command>
				<Command Description="对 (@InterleaveName@) 模式的通道 (@OpenChannel@) 进行校准" 
					InstrumentationName="GHz_MSO8000HD"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_TiAdc_MSO8000X @InterleaveName@,@OpenChannel@,Low,100,100,10000,0.3,0.3,128,ANA_8G"	
					ProgramFuncOverSec="400"		
					></Command>
			</ForeachLoop>
			<Command Description="目标示波器状态准备：系统配置:打开数字触发、打开DSP"
					InstrumentationName="GHz_MSO8000HD"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_AcqDigitTrigger:true,bEnable_Dsp:true,bEnable_CorrectTiAdc:true,bEnable_OpenCrystal:false"
			></Command>
			<Command Description="保存校准数据" 
					InstrumentationName="GHz_MSO8000HD"
					IsProgramFunc="true"
					ProgramFuncName="BatchTaskPart_SaveCaliDataToFile TiAdc_PhaseOffsetGain_JiHe_MSO8000X"
			></Command>	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>