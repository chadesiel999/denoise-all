<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->
<!--
	//valuelist="30,20,15,15,125,4700,6000,3200,7376,3200,3200,10,10,10"
	参数定义
        	//第1个参数：其中1|2 表示通道，编号从1开始；
        	//第2个参数，表示高阻还是低阻，low=50欧姆，低阻，higf表示高阻。
        	//第3个参数，以mV为单位的档位值
        	//第4个参数，步进值
        	//第5个参数，是否校准nega_bias,为1则校准negative，为0则校准positive
       	//第6个参数，传送数据的等待时间ms
        	//第7个参数，最大等待时间
        	//第8个参数，误差容限
        	//弟9个参数，最大ratio
        	//第10个参数，最小ratio
        	//"BatchTaskPart_CaliBiasRatio 1|2|3|4|,low,@inputYscale@,@step@,0,2000,60_000,60000,0.5,65535,1"
-->
<InstrumentationAutoControlSolution SolutionDescription="JPO6000程控校准方案">
	<!--=======region 方案中使用到的仪器的定义=====-->

	<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
	<Instrumentations>
		<Instrumentation 
			Name="MD8G"
			Description="40G示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
		<Instrumentation
			Name="信号源9500B"
			Description="信号源9500B"
			DriverType="VISA"
			Address="GPIB0::19::INSTR"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="校准通道偏置系数" ImportanceTipMessage="该任务是通过程控来校准示波器的通道偏置系数。">
			<Command Description="检查信号源9500B与示波器的连接情况"
				InstrumentationName="信号源9500B"
				CommandType="check"
				SCPICmd=""
			></Command>
			<Command Description="时基档1ms" 
				InstrumentationName="MD8G"
				CommandType="scpi"
				SCPICmd=":TIM:SCAL 0.001"
			></Command>	
			<Command Description="设置通道1为SMA通道模式"
			    InstrumentationName="MD8G"
			    CommandType="scpi"
			    SCPICmd=":FACT:CHAN1:INP SMA"
			></Command>
		    <Command Description="设置通道2为SMA通道模式"
				InstrumentationName="MD8G"
				CommandType="scpi"
				SCPICmd=":FACT:CHAN2:INP SMA"
			></Command>
			<Command Description="设置通道3为SMA通道模式"
			    InstrumentationName="MD8G"
			    CommandType="scpi"
			    SCPICmd=":FACT:CHAN3:INP SMA"
			></Command>
		    	<Command Description="设置通道4为SMA通道模式"
				InstrumentationName="MD8G"
				CommandType="scpi"
				SCPICmd=":FACT:CHAN4:INP SMA"
				AfterWaitSec="1"
			></Command>
			<Command Description="源复位"
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="*RST"
				AfterWaitSec="2"
			></Command>
			<Command Description="源输出直流电压模式"
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="SCOpe DC"
					></Command>
			<Command Description="源输出50欧姆阻抗"
				InstrumentationName="信号源9500B"
				CommandType="scpi"
				SCPICmd="ROUT:SIGN:IMP 50"
			></Command>
			<ForeachLoop StartIndex="3" Count="1">
				<VarintDefine name="Channel"  valuelist="1,2,3,4"></VarintDefine>
				<Command Description="现在即将对通道@Channel@进行校准，请确保将信号源的输出接入到通道@Channel@！"
					InstrumentationName="校准仪"
					CommandType="check"
					SCPICmd=""
				></Command>
				<ForeachLoop StartIndex="4" Count="7">
					<VarintDefine name="SourceAmpVoltByV"  valuelist=" 0.001,0.001,0.001,0.001,0.5,0.5,0.5,1,1,4,4,0.001,0.001,0.001"></VarintDefine>
					<VarintDefine name="inputLevelBymV"  valuelist=" 0.5,1,2,5,10,20,50,100,200,500,1000,2000,5000,10000"></VarintDefine>
					<VarintDefine name="Step"  valuelist="10,10,10,10,10,20,50,100,100,100,100,10,10,10"></VarintDefine>
					<VarintDefine name="TotalErrorByPercent"  valuelist="0.1,0.1,0.1,0.1,1.5,1.5,1.5,1.5,1.5,1.5,1.5,0.1,0.1,0.1"></VarintDefine>
					<Command Description="所有通道,@inputLevelBymV@mV档,低阻"
						InstrumentationName="MD8G"
						CommandType="scpi"
						SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,2,1,0,0,9,0,0"
						AfterWaitSec="5"
					></Command>
					<Command Description="通道偏置调节"
						InstrumentationName="MD8G"
						CommandType="scpi"
						SCPICmd=":CHANnel@Channel@:BIAS @SourceAmpVoltByV@"
					></Command>
					<Command Description="源输出直流"
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="VOLTage -@SourceAmpVoltByV@"
					></Command>
					<Command Description="源输出打开"
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="OUTPut ON"
					></Command>
					<Command Description="通道@Channel@、@inputLevelBymV@mV档、低阻态、bias系数校准"
						InstrumentationName="MD8G"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_CaliBiasRatio @Channel@,LOW,@inputLevelBymV@,@Step@,0,2000,60000,@TotalErrorByPercent@,999999,1"
						ProgramFuncOverSec="40"
					></Command>
					<Command Description="通道恢复偏置"
						InstrumentationName="MD8G"
						CommandType="scpi"
						SCPICmd=":CHANnel@Channel@:BIAS 0"
					></Command>
					<Command Description="源电压置0"
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="VOLTage 0"
					></Command>
					<Command Description="源输出关闭"
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="OUTPut OFF"
					></Command>
				</ForeachLoop>
			</ForeachLoop>
			<Command Description="源复位"
						InstrumentationName="信号源9500B"
						CommandType="scpi"
						SCPICmd="*RST"
			></Command>			
		<Command Description="保存校准数据" 
				InstrumentationName="MD8G"
				IsProgramFunc="true"
				ProgramFuncName="BatchTaskPart_SaveCaliDataToFile PhyChannelModel2"
				></Command>	
		</Task>	
	</Tasks>		
</InstrumentationAutoControlSolution>