				<Command Description="现在即将对 “通道@OpenChannel@” 进行校准，请确保将信号源的输出接入到通道！" 
					InstrumentationName="信号源9500B"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="示波器:所有通道,20mV档,低阻50Ω,满带宽限制" 
					InstrumentationName="GHz_MSO8000HD"
