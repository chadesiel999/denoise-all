			<ConstVariantDefine name="VisualTimeRangeFileName"  value="-"></ConstVariantDefine>
			<!--==观测补偿信号后的插值倍率-->
			<ConstVariantDefine name="InterpRate"  value="-"></ConstVariantDefine>
			<!--==绘图标致-->
			<ConstVariantDefine name="FigureIllustrationSw"  value="-"></ConstVariantDefine>
			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="1,4"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="1,4"></VarintDefine>
				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="inputLevelBymV"   valuelist="50,100,200,1000,100,500,2000,10000"></VarintDefine>
					<Command Description="生成校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_CombSignal_PFC.dll,
						CoefficientType=PFC,
						Channel=CH@OpenChannel@,
						SaveCoefficientFileName=PFC_TiadcQuantied_@CoeQuantiBit@bit.txt,
						SourceFiles_Path=PFCDataFiles,
						SourceFilesFilterPrefixName=WaveData_C@OpenChannel@_,
						DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						DebugSaveFilePrefixName=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						@InterleaveName@,
						OtherParameter=10e6 10e6 20e9 8.5e9 800e3 @RefwaveFileName@ 12 2048 1e9 - .\Resources\UnconcernedFreqFileNameC3.txt 100 - - - -">
					</Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送TiAdc校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=PFC,
						CoeQuantiBit=0,
						CoefficientKey=PFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=TimeDomainPFCCoe.txt,
						MagCompOrder=0"
				    ></Command>		
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送IFC校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams
