			<VarintDefine name="UnconcernedFreqFileName"  valuelist=".\Resources\UnconcernedFreqFileNameC3.txt,.\Resources\UnconcernedFreqFileNameC3.txt"></VarintDefine>
			<!--==FIR系数的保留精度-->
			<ConstVariantDefine name="Threshold"  value="0.5e-2"></ConstVariantDefine>
