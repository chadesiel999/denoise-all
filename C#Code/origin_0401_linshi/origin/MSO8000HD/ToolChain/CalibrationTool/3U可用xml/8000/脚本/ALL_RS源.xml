<?xml version="1.0" encoding="utf-8" ?>
<!--=======region 重要说明=====-->
<!--DriverType 目前只支持 VISA; 我们自己的只支持UU_ETHERNET(JPO6000), UU_USB374(示波表)-->
<!--CommandType 有2两种:check和scpi，check用于弹出准备就绪与否的对话框;scpi为SCPI命令，需要指定仪器-->
<!--AfterWaitSec 表示执行一条scpi命令后，需要等待的时间(以秒为单位)-->
<!--QueryOvertimeSec 表示执行查询命令时的超时时间(以秒为单位)。对有些操作，仪器端可能需要花费较长的时间后才能查询，比如校准。在此期间如果有比较等待操作，就需要多次执行，直到超时-->
<!--基本概念：一个文件称为一个解决方案，一个方案中包含多个任务，一个任务包含一系列的命令-->
<!--一个方案中使用的所有仪器在Instrumentations 段定义，在后续的命令中的InstrumentationName 必须使用该段中Name字段 中的内容==-->
<!--如果使用厂家自用的校准工具，对待校准的仪器（示波器），请在仪器段中对该仪器使用IsOurTargetDso="1"来标识，其地址可以为空。==-->
<!--==对使用新的厂家提供的校准工具进行校准时，在Command 段，可以使用程序自定义的函数来校准==-->
<!--==此时，包括3个标签：IsProgramFunc（指示是否该命令是程序函数来完成），ProgramFuncName(程序函数的名称，有程序员提供)，ProgramFuncOverSec（程序函数超时时间，秒）==-->

<!--=======endregion 重要说明=====-->

<InstrumentationAutoControlSolution SolutionDescription="Afc扫频方案">
	<!--=======region 方案中使用到的仪器的定义=====-->
	<Instrumentations>
		<Instrumentation 
			Name="信号源RS"
			Description="信号源RS"
			DriverType="VISA"
			Address="USB0::0x0AAD::0x0054::182860::INSTR"
			Timeout="0"
		></Instrumentation>
		<!--== 待校准的目标仪器，使用此标识，并可不标识Address标签==-->
		<Instrumentation 
			Name="GHz_MSO8000X"
			Description="GHz_MSO8000X示波器"
			DriverType="VISA"
			IsOurTargetDso="true"
			Timeout="0"
			></Instrumentation>
	</Instrumentations>
	<!--=======endregion 方案中使用到的仪器的定义=====-->
	
	<!--=======region 方案中任务列表=====-->
	<Tasks>
		<Task Description="对各个通道，阻抗，垂直档位，进行Afc扫频。" ImportanceTipMessage="该任务是通过程控来对各个通道，阻抗，垂直档位，进行Afc扫频。">
			<Group Description="信号源及示波器控制">
				<Command Description="检查信号源与示波器的连接情况" 
					InstrumentationName="信号源RS"
					CommandType="check"
					SCPICmd=""
				></Command>
				<Command Description="信号源复位" 
					InstrumentationName="信号源RS"
					CommandType="scpi"
					SCPICmd="*RST"
				></Command>
				<Command Description="设置信号源输出频率为100MHz" 
					InstrumentationName="信号源RS"
					CommandType="scpi"
					SCPICmd="FREQ:FIXed 200MHz"
				></Command>
				
				<Command Description="设置时基到实时档（100ns/div）"
					InstrumentationName="GHz_MSO8000X"
					CommandType="scpi"
					SCPICmd=":TIM:SCAL 1E-7"
				></Command>
				<Command Description="打开正常采集模式" 
					InstrumentationName="GHz_MSO8000X"
					CommandType="scpi"
					SCPICmd=":ACQuire:TYPe NORMal"
				></Command>
				<Command Description="目标示波器状态准备：系统配置:打开数字触发、打开DSP"
					InstrumentationName="GHz_MSO8000X"
					CommandType="scpi"
					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:false,bEnable_AcqDigitTrigger:false,bEnable_Dsp:false,bEnable_CorrectTiAdc:false,"
				></Command>		
			</Group>	

			<ForeachLoop StartIndex="0" Count="6">
				<VarintDefine name="OpenChannel"  		valuelist="1		,1			,2			,3			,3		,4		"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G	,All-10G,All-10G	,C1C3-20G	,All-10G,All-10G"></VarintDefine>
				
				<Command Description="现在即将对 “通道 (@OpenChannel@) ” 进行扫频，请确保将信号源的输出接入到相应的通道！" 
					InstrumentationName="信号源RS"
					CommandType="check"
					SCPICmd=""
				></Command>

				<!--==阻抗循环==-->							
				<ForeachLoop StartIndex="0" Count="1">	
					<VarintDefine name="SourceIMPedanceName"  valuelist="50欧姆,高阻"></VarintDefine>
			                <VarintDefine name="ScanFrePointTables"  valuelist="LOW_20G,生成TiAdc校准系数扫频频点HIGH"></VarintDefine>
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,4"></VarintDefine>	
					<VarintDefine name="YScaleCount"  valuelist="3,4"></VarintDefine>
					<Group Description="常量设置">
						<ConstVariantDefine name="ScanFrequenciesFilePath" value="扫频频率点表\@InterleaveName@_8G_@BatchTaskIMPedanceSetting@.txt"></ConstVariantDefine>
						<ConstVariantDefine name="ScanFrequencyResultDataDir" value="ScanFrequencyResultData\@BatchTaskIMPedanceSetting@"></ConstVariantDefine>
						<ConstVariantDefine name="ScanFrequencyResultFixDataDir" value="DestData"></ConstVariantDefine>
					</Group>
					<Command Description="信号源:阻抗(@SourceIMPedanceName@) " 
						InstrumentationName="信号源RS"
						CommandType="scpi"
						SCPICmd="ROUT:SIGN:IMP @SourceIMPedanceSetting@"
						></Command>
					<!--==挡位循环循环==-->	
					<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
						<!--<VarintDefine name="SourceAmpVoltByMv" valuelist="0.003,0.006,0.012   ,0.03    ,0.06    ,0.12    ,0.3     ,150     ,300     ,3      ,6	,12      ,30      ,60      "></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="0.5  ,1    ,2       ,5       ,10      ,20      ,50      ,100     ,200     ,500    ,1000,2000    ,5000    ,10000   "></VarintDefine>-->

						<VarintDefine name="SourceAmpVoltByMv" valuelist="40,230,1100,200,800,1100,1100"></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,100,500,2000,10000"></VarintDefine>
						<Group Description="设置源与示波器">
							<Command Description="示波器:所有通道,@inputLevelBymV@mV档,@SourceIMPedanceName@,20MHz带宽限制" 
								InstrumentationName="GHz_MSO8000X"
								CommandType="scpi"
								SCPICmd=":FACTory:ALLSource:APPLy 1,@inputLevelBymV@,0,@DsoIMPedanceOfALLSourceAPPLySetting@,3,0,0,9,0,0"
								></Command>
							<Command Description="切到正确的交织模式" 
								InstrumentationName="GHz_MSO8000X"
								CommandType="scpi"
								SCPICmd=":FACT:CHAN:ACT @InterleaveName@"
								AfterWaitSec="4"
							></Command>
							<Command Description="示波器:通道@OpenChannel@ 满带宽" 
								InstrumentationName="GHz_MSO8000X"
								CommandType="scpi"
								SCPICmd=":CHAN@OpenChannel@:BWL FULL"
								></Command>
							<Command Description="信号源:输出电平(@SourceAmpVoltByMv@V) " 
								InstrumentationName="信号源RS"
								CommandType="scpi"
								SCPICmd="SOURce:POWer:LEVel:IMMediate:AMPLitude @SourceAmpVoltByMv@ mv"
								AfterWaitSec="1"
								></Command>	
							<Command Description="打开源1输出，用于幅度基本校准" 
								InstrumentationName="信号源RS"
								CommandType="scpi"
								SCPICmd="OUTPut1:STATe ON"
								></Command>
						</Group>

						<Command Description="模式(@InterleaveName@),通道(@OpenChannel@),阻抗(@SourceIMPedanceName@):扫频" 
							InstrumentationName="GHz_MSO8000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_ScanFrequency_MSO8000X @InterleaveName@,@OpenChannel@,@BatchTaskIMPedanceSetting@,@inputLevelBymV@,扫频频率点表\@InterleaveName@_8G_@BatchTaskIMPedanceSetting@.txt,AFCData\@BatchTaskIMPedanceSetting@,@ScanFrequencyResultFixDataDir@,USB0::0x0AAD::0x0054::182860::INSTR"	
							ProgramFuncOverSec="40"		
							></Command>
						<Command Description="源输出1打开" 
							InstrumentationName="信号源RS"
							CommandType="scpi"
							SCPICmd="OUTPut OFF"
							></Command>
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>
			<Command Description="目标示波器状态准备：系统配置:打开数字触发、打开DSP"
				InstrumentationName="GHz_MSO8000X"
				CommandType="scpi"
				SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:true,bEnable_AcqDigitTrigger:true,bEnable_CorrectTiAdc:true,bEnable_Dsp:true"
			></Command>		
		</Task>	
		<Task Description="TiADC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的ADC平坦度校准。">
		<ForeachLoop StartIndex="0" Count="2">
			<VarintDefine name="OpenChannel"  		valuelist="1 , 3"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G	,C1C3-20G"></VarintDefine>
			<!--==TIADC的路数-->
			<VarintDefine name="TiPath"  valuelist="2,2"></VarintDefine>
			<!--==系统采样率,单位Hz-->
			<VarintDefine name="SamplingRate"  valuelist="20,20"></VarintDefine>
			<!--==补偿滤波器的长度-->
			<VarintDefine name="CompLength"  valuelist="2048,2048"></VarintDefine>
			<!--==FPGA中系数的量化精度-->
			<VarintDefine name="CoeQuantiWidth"  valuelist="12,12"></VarintDefine>
			<!--==阻抗循环==-->
			<ForeachLoop StartIndex="0" Count="1">
				<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
				<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
				<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
				<VarintDefine name="YScaleStart"  valuelist="1,4"></VarintDefine>
				<VarintDefine name="YScaleCount"  valuelist="1,4"></VarintDefine>
				<!--==挡位循环循环==-->
				<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
					<VarintDefine name="inputLevelBymV"   valuelist="50,100,200,1000,100,500,2000,10000"></VarintDefine>
					<Command Description="通道@OpenChannel@，阻抗@BatchTaskIMPedanceSetting@，档位@inputLevelBymV@，生成TiAdc校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_TIADC.dll,
						CoefficientType=TI,
						Channel=CH@OpenChannel@,
						SaveCoefficientFileName=TiAdc_TiadcQuantied_@CoeQuantiWidth@bit.txt,
						SourceFiles_Path=AFCData\@BatchTaskIMPedanceSetting@\@InterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
						SourceFilesFilterPrefixName=Data_,
						DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						DebugSaveFilePrefixName=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_,
						@InterleaveName@,
						OtherParameter=@SamplingRate@ @TiPath@ @CompLength@ @CoeQuantiWidth@ 50">
					</Command>
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送TiAdc校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams 
						CoefficientType=TI,
						CoeQuantiBit=0,
						CoefficientKey=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=TiadcCoeFreqDomain.txt,
						MagCompOrder=0,"
				    ></Command>		
					<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送TiAdc校准数据"
						InstrumentationName="GHz_MSO8000X"
						IsProgramFunc="true"
						ProgramFuncName="BatchTaskPart_SendCoefficientParams
						CoefficientType=TI,
						CoeQuantiBit=@CoeQuantiBit@,
						CoefficientKey=TI_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@,
						SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
						SaveCoefficientPathAndFileName=_TiadcQuantied_@CoeQuantiBit@Bit.txt,
						MagCompOrder=0,"
				    ></Command>	
				</ForeachLoop>
			</ForeachLoop>
		</ForeachLoop>
    </Task>
		<Task Description="AFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的ADC平坦度校准。">
			<ForeachLoop StartIndex="0" Count="6">
				<VarintDefine name="OpenChannel"  		valuelist="1		,1			,2			,3			,3		,4		"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G	,All-10G,All-10G	,C1C3-20G	,All-10G,All-10G"></VarintDefine>
				<!--==是采样率（单位Hz)-->
				<VarintDefine name="SamplingRate"  valuelist="20e9,10e9,10e9,20e9,10e9,10e9"></VarintDefine>
				<!--==幅频补偿滤波器的阶数阶数越大，补偿精度越高-->
				<VarintDefine name="MagCompOrder"  valuelist="81,51,51,81,51,51"></VarintDefine>
				<!--==阻带频率（Hz）-->
				<VarintDefine name="StopBandFreq"  valuelist="9.0e9,4.9e9,4.9e9,9.0e9,4.9e9,4.9e9"></VarintDefine>
				<!--==通带频率（Hz）-->
				<VarintDefine name="PassBandFreq"  valuelist="8.3e9,4e9,4e9,8.3e9,4e9,4e9"></VarintDefine>
				<!--==频域补偿结构中的FFT点数-->
				<VarintDefine name="FFTCompLen"  valuelist="2048,1024,1024,2048,1024,1024"></VarintDefine>
				
				<!--==FPGA中的系数量化位宽 -->
				<ConstVariantDefine name="CoeQuantiBit" value="12"></ConstVariantDefine>
				
				<!--==目标频响的曲线-->
				<ConstVariantDefine name="GoalResponseFileName"  value=".\Resources\Response8G_@InterleaveName@.txt"></ConstVariantDefine>
				<!--==FFT估计的长度-->
				<VarintDefine name="FFTEstimationLen"  valuelist="5e3,5e3,5e3,5e3,5e3,5e3"></VarintDefine>
				
				<!--==目标频响的频率间隔-->
				<ConstVariantDefine name="FreqGap"  value="100MHz"></ConstVariantDefine>
				<!--==幅度拟合精度-->
				<ConstVariantDefine name="FitSmoothingParam_Mag"  value="0.99999999"></ConstVariantDefine>
				<!--==迭代的步长-->
				<ConstVariantDefine name="StepLen"  value="0.001"></ConstVariantDefine>
				<!--==迭代的次数-->
				<ConstVariantDefine name="TraingTimes"  value="1000"></ConstVariantDefine>
				
				<!--==阻抗循环==-->
				<ForeachLoop StartIndex="0" Count="1">
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>
					<VarintDefine name="YScaleCount"  valuelist="3,4"></VarintDefine>
	
					<!--==挡位循环循环==-->
					<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
						<VarintDefine name="SourceAmpVoltByMv" valuelist="100,200,1100,200,800,1100,1100"></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,100,500,2000,10000"></VarintDefine>
						<Command Description="通道@OpenChannel@，阻抗@BatchTaskIMPedanceSetting@，档位@inputLevelBymV@，生成AFC校准数据"
							InstrumentationName="GHz_MSO8000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_AFC.dll,
							CoefficientType=AFC,
							Channel=CH@OpenChannel@,
							SaveCoefficientFileName=FreqDomainAFCCoe_@CoeQuantiBit@Bit.txt,
							SourceFiles_Path=AFCData\@BatchTaskIMPedanceSetting@\@InterleaveName@_CH@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							SourceFilesFilterPrefixName=Data_,
							DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
							DebugSaveFilePrefixName=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							@InterleaveName@,
							OtherParameter=@SamplingRate@ @MagCompOrder@ .\Resources\MergedResponse8G_@InterleaveName@.txt @PassBandFreq@ @StopBandFreq@ @FFTEstimationLen@ @CoeQuantiBit@ @FFTCompLen@"
						></Command>
						<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送AFC校准数据"
							InstrumentationName="GHz_MSO8000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_SendCoefficientParams 
							CoefficientType=AFC,
							CoeQuantiBit=0,
							CoefficientKey=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
							SaveCoefficientPathAndFileName=TimeDomainAFCCoe.txt,
							MagCompOrder=0"
						></Command>		
						<Command Description="通道@OpenChannel@ 阻抗：@BatchTaskIMPedanceSetting@ 档位：@inputLevelBymV@mv 发送AFC校准数据"
							InstrumentationName="GHz_MSO8000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_SendCoefficientParams
							CoefficientType=AFC,
							CoeQuantiBit=@CoeQuantiBit@,
							CoefficientKey=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							SaveCoefficientPath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
							SaveCoefficientPathAndFileName=FreqDomainAFCCoe_@CoeQuantiBit@Bit.txt,
							MagCompOrder=@MagCompOrder@,"
						></Command>						
					</ForeachLoop>
				</ForeachLoop>
			</ForeachLoop>	  
		</Task>
		<Task Description="IFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的TiAdc和AFC">
			<ForeachLoop StartIndex="0" Count="2">
				<VarintDefine name="OpenChannel"  		valuelist="1,3"></VarintDefine>
				<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G	,C1C3-20G"></VarintDefine>
				<!--==FPGA中的系数量化位宽-->
				<VarintDefine name="QuantiBitFPGA"  valuelist="12,12"></VarintDefine>
				<!--==合并的模式-->
				<VarintDefine name="MergingMode"  valuelist="TI_AFC,TI_AFC"></VarintDefine>
				<!--==频域补偿结构中的FFT点数-->
				<VarintDefine name="FFTCompLen"  valuelist="2048,2048"></VarintDefine>
				
				<!--==AFC时域滤波器系数-->
				<ConstVariantDefine name="AFCTimeCoeFileName" value="-"></ConstVariantDefine>
				<!--==PFC时域滤波器系数-->
				<ConstVariantDefine name="PFCTimeCoeFileName" value="-"></ConstVariantDefine>
				<!--==TIADC频域系数的绝对地址 -->
				<ConstVariantDefine name="TIADCFreqCoeFileName" value="-"></ConstVariantDefine>		
				<!--==绘图标致 -->
				<ConstVariantDefine name="FigureIllustrationSw" value="OFF"></ConstVariantDefine>
				
				<!--==阻抗循环==-->
				<ForeachLoop StartIndex="0" Count="1">
					<VarintDefine name="SourceIMPedanceSetting"  valuelist="50,1E6"></VarintDefine>
					<VarintDefine name="BatchTaskIMPedanceSetting"  valuelist="LOW,HIGH"></VarintDefine>
					<VarintDefine name="DsoIMPedanceOfALLSourceAPPLySetting"  valuelist="2,0"></VarintDefine>
					<VarintDefine name="YScaleStart"  valuelist="0,3"></VarintDefine>
					<VarintDefine name="YScaleCount"  valuelist="3,4"></VarintDefine>
	
					<!--==挡位循环循环==-->
					<ForeachLoop StartIndex="@YScaleStart@" Count="@YScaleCount@">
						<VarintDefine name="SourceAmpVoltByMv" valuelist="100,200,1100,200,800,1100,1100"></VarintDefine>
						<VarintDefine name="inputLevelBymV"   valuelist="20,100,1000,100,500,2000,10000"></VarintDefine>				
						<Command Description="通道@OpenChannel@，阻抗@BatchTaskIMPedanceSetting@，档位@inputLevelBymV@，生成IFC校准数据"
							InstrumentationName="GHz_MSO8000X"
							IsProgramFunc="true"
							ProgramFuncName="BatchTaskPart_GenerateCoefficientByCommonMatlabDLL MatLabDLLName=.\JiHe_MSO8000X\MatlabDLL\MatlabGenerateCoefficientsTable_CoeMerging.dll,
							CoefficientType=IFC,
							Channel=CH@OpenChannel@,
							SaveCoefficientFileName=MergedCompCoeSpectrum_TI_AFC_@QuantiBitFPGA@Bit.txt,
							SourceFiles_Path=AFCData\Coefficient_@InterleaveName@_CH@OpenChannel@,
							SourceFilesFilterPrefixName=AFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							DebugSaveFilePath=CoefficientResult\Coefficient_@InterleaveName@_CH@OpenChannel@,
							DebugSaveFilePrefixName=IFC_@InterleaveName@_C@OpenChannel@_@BatchTaskIMPedanceSetting@_@inputLevelBymV@Mv,
							@InterleaveName@,
