					SCPICmd=":FACT:CALI:SPEC:DATA DebugVariant,bEnable_DigitTrigger:false,bEnable_CorrectTiAdc:true"
			></Command>	
			</Group>
			<ForeachLoop StartIndex="0" Count="2">
