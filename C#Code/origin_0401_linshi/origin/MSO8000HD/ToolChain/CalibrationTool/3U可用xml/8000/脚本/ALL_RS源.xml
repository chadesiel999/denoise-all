		<Task Description="PFC系数生成" ImportanceTipMessage="该任务是通过程控来校准示波器的上升时间和相位。">
		<ForeachLoop StartIndex="0" Count="2">
			<VarintDefine name="OpenChannel"  		valuelist="1,3"></VarintDefine>
			<VarintDefine name="InterleaveName"  	valuelist="C1C3-20G,C1C3-20G"></VarintDefine>
			<!--==广谱信号的基频频率-->
			<ConstVariantDefine name="InputSignalFreqByHz"  value="10e6"></ConstVariantDefine>
			<!--==输入广谱信号的谐波频率间隔-->
			<ConstVariantDefine name="InputSignalHarmonicGapByHz"  value="10e6"></ConstVariantDefine>
			<!--==系统采样率,单位Hz-->
			<ConstVariantDefine name="SamplingRateBySps"  value="20e9"></ConstVariantDefine>
